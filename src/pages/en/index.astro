---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
// import Logos from '@/components/Logos.astro'; // hidden: re-enable once real client logos exist
import Hub from '@/components/Hub.astro';
import Demo from '@/components/Demo.astro';
import BookDemo from '@/components/BookDemo.astro';
import Pricing from '@/components/Pricing.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Reedly · The first field intelligence for tourism"
  description="From every client meeting, Reedly surfaces needs, commitments, opportunities and risks into structured reports and a centralized Hub for the whole team. Free trial."
  lang="en"
  hreflang={{ fr: '/fr', en: '/en' }}
>
  <!-- Cursor glow effect -->
  <div id="cursor-glow"></div>

  <Nav />

  <main class="z1">
    <Hero />
    <Demo />
    <Hub />
    {/* <Logos /> hidden until real client logos exist */}
    <BookDemo />
    <Pricing />
  </main>

  <Footer />

  <!-- Main interactive JS (i18n, animations, ticker, pricing toggle, FAQ, etc.) -->
  <script src="/main.js" is:inline></script>
</Layout>
