---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/blog.css';

const POSTS_PER_PAGE = 6;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((p) => p.data.lang === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="Blog — Reedly"
  description="Practical guides for B2B field sales reps. Reports, tools, AI, productivity."
  lang="en"
  hreflang={{ fr: '/fr/blog', en: '/en/blog' }}
>
  <Nav />

  <main class="z1">
    <section class="blog-hero">
      <div class="inner">
        <h1>Blog</h1>
        <p>Practical guides for field sales teams</p>
      </div>
    </section>

    <section class="section">
      <div class="inner">
        <div class="blog-grid" id="blog-grid">
          {posts.map((post, i) => (
            <a
              class={`blog-card reveal ${i >= POSTS_PER_PAGE ? 'blog-card--hidden' : ''}`}
              href={`/en/blog/${post.id}`}
              data-page={Math.floor(i / POSTS_PER_PAGE) + 1}
            >
              <div class="blog-card__date">{formatDate(post.data.date)}</div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="blog-card__link">Read</div>
            </a>
          ))}
        </div>

        {totalPages > 1 && (
          <nav class="blog-pagination" id="blog-pagination" aria-label="Blog pagination" data-total={totalPages}>
            <button class="blog-pagination__btn" id="pagination-prev" disabled aria-label="Previous page">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
              <span>Previous</span>
            </button>
            <div class="blog-pagination__pages" id="pagination-pages">
              {Array.from({ length: totalPages }, (_, i) => (
                <button
                  class={`blog-pagination__page ${i === 0 ? 'blog-pagination__page--active' : ''}`}
                  data-page={i + 1}
                  aria-label={`Page ${i + 1}`}
                  aria-current={i === 0 ? 'page' : undefined}
                >
                  {i + 1}
                </button>
              ))}
            </div>
            <button class="blog-pagination__btn" id="pagination-next" aria-label="Next page">
              <span>Next</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </nav>
        )}
      </div>
    </section>
  </main>

  <Footer />

  <script src="/main.js" is:inline></script>

  {totalPages > 1 && (
    <script is:inline>
      (function () {
        var current = 1;
        var total = parseInt(document.getElementById('blog-pagination').dataset.total);
        var cards = document.querySelectorAll('#blog-grid .blog-card');
        var pages = document.querySelectorAll('.blog-pagination__page');
        var prev = document.getElementById('pagination-prev');
        var next = document.getElementById('pagination-next');

        function go(page) {
          current = page;
          cards.forEach(function (c) {
            var p = parseInt(c.dataset.page);
            if (p === current) {
              c.classList.remove('blog-card--hidden');
            } else {
              c.classList.add('blog-card--hidden');
            }
          });
          pages.forEach(function (btn) {
            var p = parseInt(btn.dataset.page);
            if (p === current) {
              btn.classList.add('blog-pagination__page--active');
              btn.setAttribute('aria-current', 'page');
            } else {
              btn.classList.remove('blog-pagination__page--active');
              btn.removeAttribute('aria-current');
            }
          });
          prev.disabled = current === 1;
          next.disabled = current === total;
          document.querySelector('.blog-hero').scrollIntoView({ behavior: 'smooth' });
        }

        pages.forEach(function (btn) {
          btn.addEventListener('click', function () { go(parseInt(btn.dataset.page)); });
        });
        prev.addEventListener('click', function () { if (current > 1) go(current - 1); });
        next.addEventListener('click', function () { if (current < total) go(current + 1); });
      })();
    </script>
  )}
</Layout>
