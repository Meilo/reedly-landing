---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Problem from '@/components/Problem.astro';
import How from '@/components/How.astro';
import Features from '@/components/Features.astro';
import ReportPreview from '@/components/ReportPreview.astro';
import Hub from '@/components/Hub.astro';
import FinalCta from '@/components/FinalCta.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Reedly Solution — AI-powered field meeting reports"
  description="Record your field meetings, Reedly generates a structured report in 11 sections in under 2 minutes. Transcription, diarization, industry vocabulary."
  lang="en"
  hreflang={{ fr: '/fr/solution', en: '/en/solution' }}
>
  <div id="cursor-glow"></div>

  <Nav />

  <main class="z1">

    <!-- ── Solution Hero (unique) ── -->
    <section class="comp-hero">
      <div class="inner">
        <div class="reveal">
          <div class="section__eyebrow" data-i18n="solution.hero.eyebrow">Solution</div>
          <h1 data-i18n-html="solution.hero.title">
            Your sales reps sell.<br /><em>Reedly documents.</em>
          </h1>
          <p class="comp-hero__lead" data-i18n="solution.hero.lead">
            Reedly is the AI agent that turns every field meeting into a structured report
            in 11 sections — no typing, nothing forgotten. From recording to team management,
            discover how it works.
          </p>
        </div>
      </div>
    </section>

    <Problem />
    <How />
    <Features />
    <ReportPreview />
    <Hub />

    <!-- ── Use Cases (unique to /en/solution) ── -->
    <section class="section section--alt" id="use-cases">
      <div class="inner">
        <div class="reveal">
          <div class="section__eyebrow" data-i18n="solution.usecases.eyebrow">Use cases</div>
          <h2 data-i18n-html="solution.usecases.title">
            One tool. <em>Every field industry.</em>
          </h2>
          <p class="section__lead" data-i18n="solution.usecases.lead">
            Reedly adapts to your industry's vocabulary and challenges. The AI doesn't do generic — it reasons with the terms of your business.
          </p>
        </div>
        <div class="features-grid">
          <article class="feature-card reveal reveal-delay-1">
            <div class="feature-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <h3 data-i18n="solution.usecases.card1.title">B2B Tourism</h3>
            <p data-i18n="solution.usecases.card1.text">
              Tour operators, allotment, DMC, yield, MICE — Reedly masters professional tourism vocabulary. Your agency visit reports speak the language of the sector.
            </p>
          </article>
          <article class="feature-card reveal reveal-delay-1">
            <div class="feature-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
              </svg>
            </div>
            <h3 data-i18n="solution.usecases.card2.title">Real Estate</h3>
            <p data-i18n="solution.usecases.card2.text">
              Property visits, owner prospecting, mandates — capture every field exchange and find the commitments, objections, and opportunities from each prospect.
            </p>
          </article>
          <article class="feature-card reveal reveal-delay-2">
            <div class="feature-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
              </svg>
            </div>
            <h3 data-i18n="solution.usecases.card3.title">Pharma & Medical</h3>
            <p data-i18n="solution.usecases.card3.text">
              Medical visits, prescriber follow-up, conventions — Reedly structures complex exchanges with healthcare professionals. Adapted terminology, built-in compliance.
            </p>
          </article>
          <article class="feature-card reveal reveal-delay-2">
            <div class="feature-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.384-3.197m0 0a2.25 2.25 0 00-3.285 2.114v7.468a2.25 2.25 0 003.285 2.114L12 19.75l5.964 3.917a2.25 2.25 0 003.285-2.114v-7.468a2.25 2.25 0 00-3.285-2.114L12 15.75l-5.58-3.58z" />
              </svg>
            </div>
            <h3 data-i18n="solution.usecases.card4.title">B2B Services & Industry</h3>
            <p data-i18n="solution.usecases.card4.text">
              Long sales cycles, multiple stakeholders, technical specifications — Reedly captures the complexity of your meetings and structures it into concrete actions.
            </p>
          </article>
        </div>
      </div>
    </section>

    <FinalCta />
  </main>

  <Footer />

  <script src="/main.js" is:inline></script>
</Layout>
