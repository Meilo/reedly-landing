---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Pricing from '@/components/Pricing.astro';
import Faq from '@/components/Faq.astro';
import FinalCta from '@/components/FinalCta.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  title="Tarifs Reedly — Equipe 69 EUR/mois, Entreprise sur devis"
  description="Decouvrez les tarifs Reedly : plan Equipe a 69 EUR/utilisateur/mois, plan Entreprise sur devis. Rapports illimites, Hub manager, vocabulaire metier, support prioritaire. Essai 7 jours gratuit."
>
  <div id="cursor-glow"></div>

  <Nav />

  <main class="z1">

    <!-- ── Pricing Hero (unique) ── -->
    <section class="comp-hero">
      <div class="inner">
        <div class="reveal">
          <div class="section__eyebrow" data-i18n="tarifs.hero.eyebrow">Tarifs</div>
          <h1 data-i18n-html="tarifs.hero.title">
            L'IA terrain la plus complete.<br /><em>Au prix le plus juste.</em>
          </h1>
          <p class="comp-hero__lead" data-i18n="tarifs.hero.lead">
            3x moins cher que Modjo, 10x moins cher que Gong — et Reedly fait plus : rapports structures,
            vocabulaire metier, Hub manager. Essai 7 jours gratuit, sans carte bancaire.
          </p>
        </div>
      </div>
    </section>

    <Pricing />

    <!-- ── ROI / Time saved (unique to /tarifs) ── -->
    <section class="section section--alt" id="roi">
      <div class="inner">
        <div class="reveal">
          <div class="section__eyebrow" data-i18n="tarifs.roi.eyebrow">Retour sur investissement</div>
          <h2 data-i18n-html="tarifs.roi.title">
            Ce que Reedly fait gagner<br /><em>a votre equipe.</em>
          </h2>
          <p class="section__lead" data-i18n="tarifs.roi.lead">
            Chaque commercial passe en moyenne 45 minutes par jour a rediger des comptes-rendus.
            Avec Reedly, c'est 2 minutes. Faites le calcul.
          </p>
        </div>
        <div class="problem-grid">
          <article class="problem-card reveal reveal-delay-1">
            <div class="problem-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
              </svg>
            </div>
            <h3 data-i18n="tarifs.roi.card1.title">3h30 recuperees par semaine</h3>
            <p data-i18n="tarifs.roi.card1.text">
              Par commercial. Soit 15 heures par mois reaffectees a la vente, a la relation client
              ou aux rendez-vous supplementaires.
            </p>
          </article>
          <article class="problem-card reveal reveal-delay-2">
            <div class="problem-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
              </svg>
            </div>
            <h3 data-i18n="tarifs.roi.card2.title">Rentabilise des le 1er mois</h3>
            <p data-i18n="tarifs.roi.card2.text">
              A 69 EUR/mois par utilisateur, il suffit d'un rendez-vous supplementaire converti
              pour couvrir le cout annuel de Reedly.
            </p>
          </article>
          <article class="problem-card reveal reveal-delay-3">
            <div class="problem-card__icon">
              <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
              </svg>
            </div>
            <h3 data-i18n="tarifs.roi.card3.title">0 information perdue</h3>
            <p data-i18n="tarifs.roi.card3.text">
              Chaque engagement, chaque objection, chaque opportunite est capturee et structuree.
              Le manager voit tout en temps reel depuis le Hub.
            </p>
          </article>
        </div>
      </div>
    </section>

    <Faq />
    <FinalCta />
  </main>

  <Footer />

  <script src="/main.js" is:inline></script>
</Layout>
