---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
// import Logos from '@/components/Logos.astro'; // masqué : réactiver quand de vrais logos clients existeront
import How from '@/components/How.astro';
import Hub from '@/components/Hub.astro';
import Demo from '@/components/Demo.astro';
import BookDemo from '@/components/BookDemo.astro';
import Pricing from '@/components/Pricing.astro';
import Footer from '@/components/Footer.astro';
---

<Layout
  hreflang={{ fr: '/fr', en: '/en' }}
>
  <!-- Cursor glow effect -->
  <div id="cursor-glow"></div>

  <Nav />

  <main class="z1">
    <Hero />
    <Demo />
    <How />
    <Hub />
    {/* <Logos /> masqué jusqu'à avoir de vrais logos clients */}
    <BookDemo />
    <Pricing />
  </main>

  <Footer />

  <!-- Main interactive JS (i18n, animations, ticker, pricing toggle, FAQ, etc.) -->
  <script src="/main.js" is:inline></script>
</Layout>
