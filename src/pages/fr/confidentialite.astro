---
import Footer from '@/components/Footer.astro';
import LegalPage from '@/components/LegalPage.astro';
import Layout from '@/layouts/Layout.astro';

const sections = [
  {
    title: 'Introduction',
    paragraphs: [
      "Reedly ('nous', 'notre') exploite l'application mobile Reedly (l'Application). Cette Politique de Confidentialite explique comment nous collectons, utilisons et protegeons vos informations lorsque vous utilisez notre Application.",
      "Reedly est un outil d'enregistrement de reunions et de generation de rapports concu pour les professionnels. En utilisant l'Application, vous acceptez la collecte et l'utilisation des informations conformement a cette politique.",
    ],
  },
  {
    title: 'Informations collectees',
    paragraphs: [
      "Informations de compte : Lors de la creation de votre compte, nous collectons votre adresse email, votre pseudonyme, et eventuellement vos nom et prenom.",
      "Donnees de profil : Toute information que vous ajoutez a votre profil, y compris votre nom et votre avatar.",
      "Enregistrements audio : Lorsque vous utilisez la fonction d'enregistrement, l'audio est temporairement traite pour generer des transcriptions et des rapports structures. Les fichiers audio sont envoyes a Mistral pour la transcription.",
      "Contenu genere : Les rapports et syntheses crees a partir de vos enregistrements sont stockes dans votre compte.",
      "Donnees d'utilisation : Nous collectons des donnees d'utilisation anonymes (ecrans visites, fonctionnalites utilisees) pour ameliorer l'Application via PostHog.",
      "Informations sur l'appareil : Type d'appareil, version du systeme d'exploitation et version de l'application.",
    ],
  },
  {
    title: 'Informations que nous ne collectons pas',
    paragraphs: [
      'Nous ne collectons pas de donnees de localisation precise.',
      "Nous n'accedons pas a vos contacts, calendrier ou autres donnees personnelles.",
      'Nous ne vendons pas vos informations personnelles a des tiers.',
      "Nous ne conservons pas les fichiers audio bruts apres la transcription.",
    ],
  },
  {
    title: 'Utilisation de vos informations',
    paragraphs: [
      "Nous utilisons les informations collectees pour :\n\n• Fournir et maintenir l'Application\n• Authentifier votre compte\n• Transcrire vos enregistrements de reunions via l'IA\n• Generer des rapports structures et des syntheses\n• Vous envoyer des notifications importantes (ex. alertes de securite)\n• Ameliorer l'Application en fonction des usages\n• Corriger les bugs et assurer la stabilite",
    ],
  },
  {
    title: 'Services tiers',
    paragraphs: [
      'Notre Application utilise les services tiers suivants :\n\n• Supabase — Authentification et base de donnees (supabase.com/privacy)\n• Mistral — Transcription audio et generation de rapports (mistral.ai/fr/terms#privacy)\n• PostHog — Analytique (posthog.com/privacy)\n• RevenueCat — Achats in-app (revenuecat.com/privacy)\n• Stripe — Achats (stripe.com/privacy)\n• Sentry — Error tracking (sentry.io/privacy)\n• Expo — Build et mises a jour (expo.dev/privacy)',
    ],
  },
  {
    title: 'Stockage et securite des donnees',
    paragraphs: [
      'Vos donnees sont stockees sur des serveurs securises fournis par Supabase (heberges sur AWS).',
      'Toutes les donnees sont chiffrees en transit (TLS/SSL) et au repos.',
      "Les enregistrements audio sont traites en temps reel et ne sont pas stockes de maniere permanente sur nos serveurs.",
      "Nous mettons en oeuvre des mesures de securite conformes aux standards de l'industrie.",
    ],
  },
  {
    title: 'Vos droits',
    paragraphs: [
      'Vous avez le droit de :\n\n• Acceder a vos donnees personnelles\n• Corriger des donnees inexactes\n• Supprimer votre compte et les donnees associees\n• Exporter vos donnees dans un format portable\n• Refuser le suivi analytique',
      'Pour exercer ces droits, contactez-nous a support@reedly.ai.',
    ],
  },
  {
    title: 'Conservation des donnees',
    paragraphs: [
      'Les donnees de compte sont conservees tant que votre compte est actif.',
      'Si vous supprimez votre compte, vos donnees sont definitivement supprimees sous 30 jours.',
      'Les donnees analytiques anonymes peuvent etre conservees indefiniment sous forme agregee.',
    ],
  },
  {
    title: 'Protection des mineurs',
    paragraphs: [
      "Notre Application n'est pas destinee aux enfants de moins de 13 ans. Nous ne collectons pas sciemment d'informations personnelles aupres d'enfants de moins de 13 ans. Si vous pensez que nous avons collecte de telles donnees, veuillez nous contacter immediatement.",
    ],
  },
  {
    title: 'Modifications de cette politique',
    paragraphs: [
      "Nous pouvons mettre a jour cette Politique de Confidentialite de temps a autre. Nous vous informerons de tout changement en publiant la nouvelle politique sur cette page, en mettant a jour la date de 'Derniere mise a jour' et en envoyant une notification via l'Application pour les changements importants.",
    ],
  },
  {
    title: 'Nous contacter',
    paragraphs: ['Pour toute question concernant cette Politique de Confidentialite, contactez-nous a :\n\nsupport@reedly.ai'],
  },
];
---

<Layout title="Confidentialite | Reedly" description="Politique de confidentialite de Reedly" hreflang={{ fr: '/fr/confidentialite', en: '/en/privacy-policy' }}>
  <LegalPage
    title="Politique de Confidentialite"
    lastUpdated="Derniere mise a jour : 18 fevrier 2026"
    backHref="/fr"
    sections={sections}
  />
  <Footer />
</Layout>
