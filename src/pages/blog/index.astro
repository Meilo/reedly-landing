---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/blog.css';

const allPosts = await getCollection('blog');
const frPosts = allPosts
  .filter((p) => p.data.lang === 'fr')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const enPosts = allPosts
  .filter((p) => p.data.lang === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date, lang: string) {
  return date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout
  title="Blog — Reedly"
  description="Guides pratiques pour les commerciaux terrain B2B. Comptes-rendus, outils, IA, productivité."
>
  <Nav />

  <main class="z1">
    <section class="blog-hero">
      <div class="inner">
        <h1 data-i18n="blog.title">Blog</h1>
        <p data-i18n="blog.subtitle">Guides pratiques pour les commerciaux terrain</p>
      </div>
    </section>

    <section class="section">
      <div class="inner">
        <div class="blog-grid" data-blog-lang="fr">
          {frPosts.map((post) => (
            <a class="blog-card reveal" href={`/blog/${post.id}`}>
              <div class="blog-card__date">{formatDate(post.data.date, 'fr')}</div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="blog-card__link" data-i18n="blog.read">Lire</div>
            </a>
          ))}
        </div>

        <div class="blog-grid" data-blog-lang="en" style="display:none;">
          {enPosts.map((post) => (
            <a class="blog-card reveal" href={`/blog/${post.id}`}>
              <div class="blog-card__date">{formatDate(post.data.date, 'en')}</div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="blog-card__link" data-i18n="blog.read">Read</div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script src="/main.js" is:inline></script>
  <script is:inline>
    (function() {
      function updateBlogLang() {
        var lang = localStorage.getItem('lang') || 'fr';
        document.querySelectorAll('[data-blog-lang]').forEach(function(el) {
          el.style.display = el.dataset.blogLang === lang ? '' : 'none';
        });
      }
      updateBlogLang();
      document.querySelectorAll('.lang-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTimeout(updateBlogLang, 50);
        });
      });
    })();
  </script>
</Layout>
