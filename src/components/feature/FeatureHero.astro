---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  cta_url: string;
  lang: 'fr' | 'en';
}
const { eyebrow, title, lead, cta_url, lang } = Astro.props;
const ctaLabel = lang === 'fr' ? 'Essayer gratuitement' : 'Try for free';
---

<section class="comp-hero">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow">{eyebrow}</div>
      <h1 set:html={title} />
      <p class="comp-hero__lead">{lead}</p>
      <div class="hero__actions">
        <a
          class="btn btn--primary btn--lg"
          href={cta_url}
          data-track-id="feature_hero_cta"
          data-track-type="trial"
          data-track-section="feature_hero"
        >{ctaLabel}</a>
      </div>
    </div>
  </div>
</section>

