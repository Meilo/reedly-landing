---
// Nav — sticky navigation bar
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isSolution = path === '/solution';
const isTarifs = path === '/tarifs' || path === '/pricing';
const isComparatif = path === '/comparatif' || path === '/comparison';
const isBlog = path.startsWith('/blog');
---

<nav class="nav z1">
  <div class="nav__inner">
    <a class="logo" href="/">
      <img src="/favicon.png" alt="Reedly" width="28" height="28" style="border-radius: 8px;" />
      <span>REEDLY</span>
    </a>

    <div class="nav__menu">
      <a class={`nav__menu-link${isSolution ? ' active' : ''}`} href="/solution" data-i18n="nav.solution" data-link-fr="/solution" data-link-en="/solution">Solution</a>
      <a class={`nav__menu-link${isTarifs ? ' active' : ''}`} href="/tarifs" data-i18n="nav.pricing" data-link-fr="/tarifs" data-link-en="/pricing">Tarifs</a>
      <a class={`nav__menu-link${isComparatif ? ' active' : ''}`} href="/comparatif" data-i18n="nav.comparatif" data-link-fr="/comparatif" data-link-en="/comparison">Comparatif</a>
      <a class={`nav__menu-link${isBlog ? ' active' : ''}`} href="/blog" data-i18n="nav.blog" data-link-fr="/blog" data-link-en="/blog">Blog</a>
    </div>

    <div class="nav__actions">
      <div class="theme-toggle" role="radiogroup" aria-label="Thème">
        <button class="theme-btn" data-theme-value="light" type="button" aria-label="Mode clair">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="dark" type="button" aria-label="Mode sombre">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="system" type="button" aria-label="Mode système">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
      </div>
      <span class="nav__sep"></span>
      <div class="lang-toggle">
        <button class="lang-btn active" data-lang="en" type="button">EN</button>
        <span class="lang-sep">/</span>
        <button class="lang-btn" data-lang="fr" type="button">FR</button>
      </div>
      <a
        class="btn btn--ghost btn--sm"
        href="https://hub.reedly.ai"
        data-i18n="nav.login"
        data-track-id="nav_login"
        data-track-type="login"
        data-track-section="nav"
      >Se connecter</a>
    </div>

    <button
      class="nav__hamburger"
      id="nav-toggle"
      data-i18n-aria-label="nav.open_menu"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <a class={`nav__mobile-link${isSolution ? ' active' : ''}`} href="/solution" data-i18n="nav.solution" data-link-fr="/solution" data-link-en="/solution">Solution</a>
    <a class={`nav__mobile-link${isTarifs ? ' active' : ''}`} href="/tarifs" data-i18n="nav.pricing" data-link-fr="/tarifs" data-link-en="/pricing">Tarifs</a>
    <a class={`nav__mobile-link${isComparatif ? ' active' : ''}`} href="/comparatif" data-i18n="nav.comparatif" data-link-fr="/comparatif" data-link-en="/comparison">Comparatif</a>
    <a class={`nav__mobile-link${isBlog ? ' active' : ''}`} href="/blog" data-i18n="nav.blog" data-link-fr="/blog" data-link-en="/blog">Blog</a>
    <div class="nav__mobile-actions">
      <a
        class="btn btn--ghost btn--md"
        href="https://hub.reedly.ai"
        data-i18n="nav.login"
        data-track-id="nav_login"
        data-track-type="login"
        data-track-section="nav"
      >Se connecter</a>
    </div>
  </div>
</nav>
