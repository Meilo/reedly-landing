---
// Nav — sticky navigation bar
---

<nav class="nav z1">
  <div class="nav__inner">
    <a class="logo" href="#">
      <img src="/favicon.png" alt="Reedly" width="28" height="28" style="border-radius: 8px;" />
      <span>REEDLY</span>
    </a>

    <div class="nav__menu">
      <a class="nav__menu-link" href="#problem" data-i18n="nav.problem">Le Problème</a>
      <a class="nav__menu-link" href="#how" data-i18n="nav.how">Comment ça marche</a>
      <a class="nav__menu-link" href="#features" data-i18n="nav.features">Fonctionnalités</a>
      <a class="nav__menu-link" href="#pricing" data-i18n="nav.pricing">Tarifs</a>
      <a class="nav__menu-link" href="#contact" data-i18n="nav.contact">Contact</a>
      <a class="nav__menu-link" href="#faq" data-i18n="nav.faq">FAQ</a>
    </div>

    <div class="nav__actions">
      <div class="lang-toggle">
        <button class="lang-btn active" data-lang="en" type="button">EN</button>
        <span class="lang-sep">/</span>
        <button class="lang-btn" data-lang="fr" type="button">FR</button>
      </div>
      <a
        class="btn btn--ghost btn--sm"
        href="#"
        data-i18n="nav.login"
        data-track-id="nav_login"
        data-track-type="login"
        data-track-section="nav"
      >Se connecter</a>
    </div>

    <button
      class="nav__hamburger"
      id="nav-toggle"
      data-i18n-aria-label="nav.open_menu"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <a class="nav__mobile-link" href="#problem" data-i18n="nav.problem">Le Problème</a>
    <a class="nav__mobile-link" href="#how" data-i18n="nav.how">Comment ça marche</a>
    <a class="nav__mobile-link" href="#features" data-i18n="nav.features">Fonctionnalités</a>
    <a class="nav__mobile-link" href="#pricing" data-i18n="nav.pricing">Tarifs</a>
    <a class="nav__mobile-link" href="#contact" data-i18n="nav.contact">Contact</a>
    <a class="nav__mobile-link" href="#faq" data-i18n="nav.faq">FAQ</a>
    <div class="nav__mobile-actions">
      <a
        class="btn btn--ghost btn--md"
        href="#"
        data-i18n="nav.login"
        data-track-id="nav_login"
        data-track-type="login"
        data-track-section="nav"
      >Se connecter</a>
    </div>
  </div>
</nav>
