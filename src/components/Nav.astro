---
// Nav — sticky navigation bar
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const isFeatures = path.includes('/solutions/');
const featuresLabel = lang === 'fr' ? 'Fonctionnalités' : 'Features';
const currentSlug = path.split('/solutions/')[1] || '';
const isTarifs = path.endsWith('/tarifs') || path.endsWith('/pricing');
const isComparatif = path.endsWith('/comparatif') || path.endsWith('/comparison');
const isBlog = path.includes('/blog');
const trialHref = `/${lang}#trial`;

const features = [
  { slugFr: 'enregistrement-vocal-rdv', slugEn: 'meeting-voice-recording', labelFr: 'Enregistrement vocal', labelEn: 'Voice Recording', descFr: 'Capturez chaque RDV en 1 tap', descEn: 'Capture every meeting in 1 tap', icon: 'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z' },
  { slugFr: 'transcription-ia', slugEn: 'ai-transcription', labelFr: 'Transcription IA', labelEn: 'AI Transcription', descFr: 'Transcription +95% de précision', descEn: '95%+ accuracy transcription', icon: 'M3 5h12M3 9h8M3 13h10M3 17h6' },
  { slugFr: 'rapport-ia', slugEn: 'ai-report', labelFr: 'Rapport structuré IA', labelEn: 'AI Structured Report', descFr: 'Rapport en 11 sections en 2 min', descEn: '11-section report in 2 min', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { slugFr: 'identification-interlocuteurs', slugEn: 'speaker-identification', labelFr: 'Identification des voix', labelEn: 'Speaker Identification', descFr: 'Qui a dit quoi dans le RDV', descEn: 'Who said what in the meeting', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z' },
  { slugFr: 'syntheses-territoriales', slugEn: 'territory-syntheses', labelFr: 'Synthèses territoriales', labelEn: 'Territory Syntheses', descFr: 'Vision stratégique du terrain', descEn: 'Strategic territory overview', icon: 'M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z' },
  { slugFr: 'hub-manager', slugEn: 'manager-hub', labelFr: 'Hub Manager', labelEn: 'Manager Hub', descFr: 'Dashboard équipe centralisé', descEn: 'Centralized team dashboard', icon: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm10 0a1 1 0 011-1h4a1 1 0 011 1v6a1 1 0 01-1 1h-4a1 1 0 01-1-1v-6z' },
  { slugFr: 'preparation-rdv', slugEn: 'meeting-preparation', labelFr: 'Préparation de RDV', labelEn: 'Meeting Preparation', descFr: 'Briefing IA avant chaque visite', descEn: 'AI briefing before each visit', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { slugFr: 'assistant-ia-manager', slugEn: 'ai-manager-assistant', labelFr: 'Max — Assistant IA', labelEn: 'Max — AI Assistant', descFr: 'Posez vos questions à l\'IA', descEn: 'Ask the AI your questions', icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
  { slugFr: 'portfolio-client', slugEn: 'client-portfolio', labelFr: 'Portfolio Client', labelEn: 'Client Portfolio', descFr: 'Fiches clients enrichies par l\'IA', descEn: 'AI-enriched client cards', icon: 'M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21' },
  { slugFr: 'base-de-connaissances', slugEn: 'knowledge-base', labelFr: 'Base de connaissances', labelEn: 'Knowledge Base', descFr: 'Documents et contexte métier', descEn: 'Documents & business context', icon: 'M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25' },
  { slugFr: 'directives-commerciales', slugEn: 'sales-directives', labelFr: 'Directives commerciales', labelEn: 'Sales Directives', descFr: 'Objectifs avec suivi IA', descEn: 'Goals with AI tracking', icon: 'M12 2a10 10 0 110 20 10 10 0 010-20zm0 4a6 6 0 100 12 6 6 0 000-12zm0 4a2 2 0 110 4 2 2 0 010-4z' },
];

---

<nav class="nav z1">
  <div class="nav__inner">
    <a class="logo" href={`/${lang}`} data-link-fr="/fr" data-link-en="/en">
      <img src="/favicon.png" alt="Reedly" width="28" height="28" style="border-radius: 8px;" />
      <span>REEDLY</span>
    </a>

    <div class="nav__menu">
      <div class="nav__dropdown">
        <button class={`nav__menu-link nav__dropdown-trigger${isFeatures ? ' active' : ''}`} type="button">
          {featuresLabel}
          <svg class="nav__dropdown-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="nav__dropdown-panel">
          <div class="nav__dropdown-list">
            {features.map((f) => (
              <a class={`nav__dropdown-item${currentSlug === (lang === 'fr' ? f.slugFr : f.slugEn) ? ' nav__dropdown-item--active' : ''}`} href={`/${lang}/solutions/${lang === 'fr' ? f.slugFr : f.slugEn}`}>
                <svg class="nav__dropdown-item-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d={f.icon} /></svg>
                <div>
                  <span class="nav__dropdown-item-label">{lang === 'fr' ? f.labelFr : f.labelEn}</span>
                  <span class="nav__dropdown-item-desc">{lang === 'fr' ? f.descFr : f.descEn}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
      <a class={`nav__menu-link${isTarifs ? ' active' : ''}`} href={lang === 'fr' ? '/fr/tarifs' : '/en/pricing'} data-i18n="nav.pricing" data-link-fr="/fr/tarifs" data-link-en="/en/pricing">Tarifs</a>
      <a class={`nav__menu-link${isComparatif ? ' active' : ''}`} href={lang === 'fr' ? '/fr/comparatif' : '/en/comparison'} data-i18n="nav.comparatif" data-link-fr="/fr/comparatif" data-link-en="/en/comparison">Comparatif</a>
      <a class={`nav__menu-link${isBlog ? ' active' : ''}`} href={`/${lang}/blog`} data-i18n="nav.blog" data-link-fr="/fr/blog" data-link-en="/en/blog">Blog</a>
    </div>

    <div class="nav__actions">
      <div class="theme-toggle" role="radiogroup" aria-label="Thème">
        <button class="theme-btn" data-theme-value="light" type="button" aria-label="Mode clair">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="dark" type="button" aria-label="Mode sombre">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <button class="theme-btn" data-theme-value="system" type="button" aria-label="Mode système">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </button>
      </div>
      <span class="nav__sep"></span>
      <div class="lang-toggle">
        <button class={`lang-btn${lang === 'en' ? ' active' : ''}`} data-lang="en" type="button">EN</button>
        <span class="lang-sep">/</span>
        <button class={`lang-btn${lang === 'fr' ? ' active' : ''}`} data-lang="fr" type="button">FR</button>
      </div>
      <a
        class="btn btn--primary btn--sm"
        href={trialHref}
        data-link-fr="/fr#trial"
        data-link-en="/en#trial"
        data-i18n="cta.try_free"
        data-track-id="nav_try_free"
        data-track-type="trial"
        data-track-section="nav"
      >Essayer gratuitement</a>
    </div>

    <button
      class="nav__hamburger"
      id="nav-toggle"
      data-i18n-aria-label="nav.open_menu"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <span class={`nav__mobile-link${isFeatures ? ' active' : ''}`}>{featuresLabel}</span>
    <div class="nav__mobile-features">
      {features.map((f) => (
        <a class="nav__mobile-feature" href={`/${lang}/solutions/${lang === 'fr' ? f.slugFr : f.slugEn}`}>
          {lang === 'fr' ? f.labelFr : f.labelEn}
        </a>
      ))}
    </div>
    <a class={`nav__mobile-link${isTarifs ? ' active' : ''}`} href={lang === 'fr' ? '/fr/tarifs' : '/en/pricing'} data-i18n="nav.pricing" data-link-fr="/fr/tarifs" data-link-en="/en/pricing">Tarifs</a>
    <a class={`nav__mobile-link${isComparatif ? ' active' : ''}`} href={lang === 'fr' ? '/fr/comparatif' : '/en/comparison'} data-i18n="nav.comparatif" data-link-fr="/fr/comparatif" data-link-en="/en/comparison">Comparatif</a>
    <a class={`nav__mobile-link${isBlog ? ' active' : ''}`} href={`/${lang}/blog`} data-i18n="nav.blog" data-link-fr="/fr/blog" data-link-en="/en/blog">Blog</a>
    <div class="nav__mobile-actions">
      <a
        class="btn btn--primary btn--md"
        href={trialHref}
        data-link-fr="/fr#trial"
        data-link-en="/en#trial"
        data-i18n="cta.try_free"
        data-track-id="nav_try_free_mobile"
        data-track-type="trial"
        data-track-section="nav_mobile"
      >Essayer gratuitement</a>
    </div>
  </div>
</nav>
