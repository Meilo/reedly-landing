---
// Hub section
---

<!-- ── Hub for managers ── -->
      <section class="section" id="hub">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="hub.eyebrow">Pour les managers</div>
            <h2 data-i18n-html="hub.title">Pilotez l'équipe depuis<br /><em>le Hub.</em></h2>
            <p class="section__lead" data-i18n="hub.lead">
              Vos commerciaux génèrent leurs rapports depuis l'app mobile. Vous pilotez depuis le
              Hub — vue transversale, synthèses, statistiques membres, tout en un coup d'œil.
            </p>
          </div>

          <div class="hub-layout">
            <div class="hub-benefits">
              <article class="benefit reveal reveal-delay-1">
                <div class="benefit__icon">
                  <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                    />
                  </svg>
                </div>
                <div>
                  <h3 data-i18n="hub.benefit1.title">Vue unifiée de toute l'équipe</h3>
                  <p data-i18n="hub.benefit1.text">
                    Tous les rapports de vos commerciaux centralisés, filtrables, avec statistiques
                    d'activité par membre.
                  </p>
                </div>
              </article>
              <article class="benefit reveal reveal-delay-2">
                <div class="benefit__icon">
                  <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M3 13.5l10-8.25L17 9l4-3M3 13.5V20h18v-6.5"
                    />
                  </svg>
                </div>
                <div>
                  <h3 data-i18n="hub.benefit2.title">Synthèses stratégiques à la demande</h3>
                  <p data-i18n="hub.benefit2.text">
                    Tendances, risques et opportunités agrégés sur la période de votre choix —
                    semaine, mois, trimestre.
                  </p>
                </div>
              </article>
              <article class="benefit reveal reveal-delay-3">
                <div class="benefit__icon">
                  <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                    />
                  </svg>
                </div>
                <div>
                  <h3 data-i18n="hub.benefit3.title">Invitations membres en 1 clic</h3>
                  <p data-i18n="hub.benefit3.text">
                    Invitez vos commerciaux par email. Ils acceptent depuis l'app mobile et leurs
                    rapports remontent automatiquement.
                  </p>
                </div>
              </article>
            </div>

            <div class="dashboard-preview reveal">
              <div class="dash">
                <div class="dash__titlebar">
                  <div class="dash__dots">
                    <div class="dash__dot dash__dot--r"></div>
                    <div class="dash__dot dash__dot--y"></div>
                    <div class="dash__dot dash__dot--g"></div>
                  </div>
                  <div class="dash__title" data-i18n="hub.dash.title">
                    reedly.ai/hub — Tableau de bord
                  </div>
                </div>
                <div class="dash__body">
                  <nav class="dash__sidebar">
                    <div class="dash__org">Tourisme Pro</div>
                    <div class="dash__nav-item dash__nav-item--active">
                      <svg fill="none" stroke-width="2" viewBox="0 0 12 12">
                        <rect x="1" y="1" width="4" height="4" rx="1" />
                        <rect x="7" y="1" width="4" height="4" rx="1" />
                        <rect x="1" y="7" width="4" height="4" rx="1" />
                        <rect x="7" y="7" width="4" height="4" rx="1" />
                      </svg>
                      <span data-i18n="hub.dash.nav">Tableau de bord</span>
                    </div>
                    <div class="dash__nav-item">
                      <svg fill="none" stroke-width="2" viewBox="0 0 12 12">
                        <path d="M2 3h8M2 6h5M2 9h7" />
                      </svg>
                      <span data-i18n="hub.dash.reports">Rapports</span>
                    </div>
                    <div class="dash__nav-item">
                      <svg fill="none" stroke-width="2" viewBox="0 0 12 12">
                        <path d="M6 1v10M1 6h10" />
                      </svg>
                      <span data-i18n="hub.dash.syntheses">Synthèses</span>
                    </div>
                    <div class="dash__nav-item">
                      <svg fill="none" stroke-width="2" viewBox="0 0 12 12">
                        <circle cx="6" cy="4" r="2.5" />
                        <path d="M1 11c0-2.76 2.24-5 5-5s5 2.24 5 5" />
                      </svg>
                      <span data-i18n="hub.dash.members">Membres</span>
                    </div>
                  </nav>
                  <div class="dash__content">
                    <div class="dash__stats">
                      <div class="dash__stat">
                        <div class="dash__stat-val">24<span>↑</span></div>
                        <div class="dash__stat-lbl" data-i18n="hub.dash.stat1">
                          Rapports ce mois
                        </div>
                      </div>
                      <div class="dash__stat">
                        <div class="dash__stat-val">6<span>–</span></div>
                        <div class="dash__stat-lbl" data-i18n="hub.dash.stat2">Membres actifs</div>
                      </div>
                      <div class="dash__stat">
                        <div class="dash__stat-val">3<span>↑</span></div>
                        <div class="dash__stat-lbl" data-i18n="hub.dash.stat3">Synthèses</div>
                      </div>
                    </div>
                    <div class="dash__report-list">
                      <div class="dash__report">
                        <div class="dash__report-info">
                          <div class="dash__report-name" data-i18n="hub.dash.r1.name">
                            RV Agence Riviera — M. Laurent
                          </div>
                          <div class="dash__report-meta" data-i18n="hub.dash.r1.meta">
                            Sophie D. · il y a 23 min
                          </div>
                        </div>
                        <div
                          class="dash__report-badge dash__report-badge--done"
                          data-i18n="hub.dash.r1.badge"
                        >
                          Généré
                        </div>
                      </div>
                      <div class="dash__report">
                        <div class="dash__report-info">
                          <div class="dash__report-name" data-i18n="hub.dash.r2.name">
                            Client Hôtels Premium — Mme Dubois
                          </div>
                          <div class="dash__report-meta" data-i18n="hub.dash.r2.meta">
                            Tom V. · il y a 1h
                          </div>
                        </div>
                        <div
                          class="dash__report-badge dash__report-badge--processing"
                          data-i18n="hub.dash.r2.badge"
                        >
                          En cours
                        </div>
                      </div>
                      <div class="dash__report">
                        <div class="dash__report-info">
                          <div class="dash__report-name" data-i18n="hub.dash.r3.name">
                            Suivi contrat TO Barcelone
                          </div>
                          <div class="dash__report-meta" data-i18n="hub.dash.r3.meta">
                            Marc R. · il y a 3h
                          </div>
                        </div>
                        <div
                          class="dash__report-badge dash__report-badge--done"
                          data-i18n="hub.dash.r3.badge"
                        >
                          Généré
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="dash__glow"></div>
            </div>
          </div>
        </div>
      </section>
