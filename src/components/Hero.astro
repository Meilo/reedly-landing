---
// Hero section
---

<!-- ── Hero ── -->
      <section class="hero">
        <div class="inner">
          <div>
            <div class="hero__pill">
              <div class="hero__pill-dot"></div>
              <span data-i18n="hero.pill"
                >Application iOS &amp; Android · Rapport en moins de 2 min</span
              >
            </div>
            <h1 data-i18n-html="hero.title">Enregistrez.<br />L'IA <em>génère le rapport.</em></h1>
            <p class="hero__sub" data-i18n="hero.sub">
              Reedly transforme chaque rendez-vous terrain en rapport structuré en moins de 2
              minutes — résumé, besoins, objections, engagements, prochaines étapes. Rien à taper.
              Rien à oublier.
            </p>
            <p class="hero__definition sr-only">
              Reedly est une application mobile iOS et Android d'enregistrement vocal destinée aux commerciaux terrain B2B.
              Elle enregistre les rendez-vous clients en arrière-plan grâce à l'enregistrement vocal mains libres, transcrit l'audio avec plus de
              95% de précision, puis génère automatiquement un rapport structuré en 11 sections en
              moins de 2 minutes. Les sections incluent le résumé exécutif, le profil client, les
              besoins exprimés, les objections et réponses, les produits discutés, les concurrents
              mentionnés, les engagements mutuels, les prochaines étapes et échéances, les
              opportunités identifiées, les risques et points de vigilance, et les recommandations
              stratégiques. L'audio est supprimé définitivement après la génération du rapport.
              Reedly propose également un Hub web pour les managers, permettant de centraliser les
              rapports de toute l'équipe et de générer des synthèses territoriales agrégées par
              semaine, mois ou trimestre.
            </p>
            <div class="hero__actions">
              <a
                class="btn btn--primary btn--lg"
                href="#trial"
                data-i18n="cta.try_free"
                data-track-id="hero_try_free"
                data-track-type="trial"
                data-track-section="hero"
                >Essayer gratuitement</a
              >
            </div>
            <div class="offline-banner" id="offline-banner" data-i18n="hero.offline">
              Mode hors ligne détecté — connexion requise pour générer des rapports.
            </div>
          </div>

          <!-- Phone mockup -->
          <div class="phone-wrap reveal">
            <div class="phone-glow"></div>
            <div class="phone">
              <div class="phone__notch">
                <div class="phone__notch-pill"></div>
              </div>
              <div class="phone__topbar">
                <svg class="phone__close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
                  <path d="M18 6L6 18M6 6l12 12"/>
                </svg>
                <span class="phone__topbar-title" data-i18n="hero.rec_label">Enregistrement</span>
                <span class="phone__topbar-spacer"></span>
              </div>
              <div class="phone__body">
                <div class="phone__recording-status" data-i18n="hero.recording_status">Enregistrement en cours...</div>
                <div class="phone__big-timer">00:05</div>
                <div class="phone__waveform">
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                  <div class="wave-bar"></div>
                </div>
              </div>
              <div class="phone__controls">
                <div class="phone__ctrl phone__ctrl--secondary">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><rect x="5" y="4" width="4" height="16" rx="1"/><rect x="15" y="4" width="4" height="16" rx="1"/></svg>
                </div>
                <div class="phone__ctrl phone__ctrl--stop">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
                </div>
                <div class="phone__ctrl phone__ctrl--secondary">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M19 21l-7-4-7 4V5a2 2 0 012-2h10a2 2 0 012 2z"/></svg>
                </div>
              </div>
            </div>

            <!-- Floating report card -->
            <div class="phone__report-float">
              <div class="phone__report-float-header">
                <div class="phone__report-float-dot"></div>
                <div class="phone__report-float-label" data-i18n="hero.report_float">
                  Rapport généré
                </div>
              </div>
              <div class="phone__report-float-sections">
                <div class="phone__report-float-section">
                  <span class="phone__report-section-icon">●</span>
                  <span class="phone__report-section-name" data-i18n="hero.float.s1">Résumé exécutif</span>
                </div>
                <div class="phone__report-float-section">
                  <span class="phone__report-section-icon">●</span>
                  <span class="phone__report-section-name" data-i18n="hero.float.s2">Besoins exprimés</span>
                </div>
                <div class="phone__report-float-section">
                  <span class="phone__report-section-icon">●</span>
                  <span class="phone__report-section-name" data-i18n="hero.float.s3">Objections &amp; réponses</span>
                </div>
                <div class="phone__report-float-section">
                  <span class="phone__report-section-icon">●</span>
                  <span class="phone__report-section-name" data-i18n="hero.float.s4">Engagements &amp; prochaines étapes</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Ticker -->
        <div class="ticker" style="margin-top: 48px">
          <div class="ticker__track" id="ticker-track">
            <span class="ticker__item" data-i18n="ticker.1"
              >Enregistrement live pendant le rendez-vous</span
            >
            <span class="ticker__item" data-i18n="ticker.2"
              >Transcription automatique haute précision</span
            >
            <span class="ticker__item" data-i18n="ticker.3">Rapport structuré en 11 sections</span>
            <span class="ticker__item" data-i18n="ticker.4">Zéro saisie manuelle</span>
            <span class="ticker__item" data-i18n="ticker.5">Export PDF en 1 clic</span>
            <span class="ticker__item" data-i18n="ticker.6"
              >Synthèses territoriales à la demande</span
            >
            <span class="ticker__item" data-i18n="ticker.7">Vocabulaire B2B sectoriel intégré</span>
            <span class="ticker__item" data-i18n="ticker.8"
              >Audio supprimé après génération — privacy by design</span
            >
            <span class="ticker__item" data-i18n="ticker.1" aria-hidden="true"
              >Enregistrement live pendant le rendez-vous</span
            >
            <span class="ticker__item" data-i18n="ticker.2" aria-hidden="true"
              >Transcription automatique haute précision</span
            >
            <span class="ticker__item" data-i18n="ticker.3" aria-hidden="true"
              >Rapport structuré en 11 sections</span
            >
            <span class="ticker__item" data-i18n="ticker.4" aria-hidden="true"
              >Zéro saisie manuelle</span
            >
            <span class="ticker__item" data-i18n="ticker.5" aria-hidden="true"
              >Export PDF en 1 clic</span
            >
            <span class="ticker__item" data-i18n="ticker.6" aria-hidden="true"
              >Synthèses territoriales à la demande</span
            >
            <span class="ticker__item" data-i18n="ticker.7" aria-hidden="true"
              >Vocabulaire B2B sectoriel intégré</span
            >
            <span class="ticker__item" data-i18n="ticker.8" aria-hidden="true"
              >Audio supprimé après génération — privacy by design</span
            >
          </div>
        </div>
      </section>
