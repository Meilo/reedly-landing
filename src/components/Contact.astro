---
// Contact — form section with Resend integration
---

<section class="section section--alt" id="contact">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow" data-i18n="contact.eyebrow">Contact</div>
      <h2 data-i18n-html="contact.title">Une question ?<br /><em>On vous répond.</em></h2>
      <p class="section__lead" data-i18n="contact.lead">
        Démonstration, partenariat, retour terrain ou simple curiosité — écrivez-nous,
        on répond sous 24h.
      </p>
    </div>

    <div class="contact__grid">
      <!-- Left: context -->
      <div class="contact__info reveal">
        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4 data-i18n="contact.f1.title">Essai gratuit</h4>
            <p data-i18n="contact.f1.text">Testez Reedly sur vos vrais rendez-vous terrain. On active votre accès après un rapide échange.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M15 10l4.553-2.069A1 1 0 0121 8.87V15.13a1 1 0 01-1.447.9L15 14M3 8h12a2 2 0 012 2v4a2 2 0 01-2 2H3a2 2 0 01-2-2v-4a2 2 0 012-2z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4 data-i18n="contact.f2.title">Démonstration live</h4>
            <p data-i18n="contact.f2.text">20 minutes pour voir Reedly en action et répondre à vos questions sur votre secteur.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4 data-i18n="contact.f3.title">Déploiement équipe & Hub</h4>
            <p data-i18n="contact.f3.text">Onboarding, formation et configuration du Hub manager — calibré pour votre équipe terrain.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4 data-i18n="contact.f4.title">Intégration CRM</h4>
            <p data-i18n="contact.f4.text">HubSpot, Salesforce, Slack, Discord — Reedly se connecte à votre stack existante.</p>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact__form-card reveal">
        <span id="trial" class="scroll-anchor" aria-hidden="true"></span>
        <form id="contact-form" novalidate>
          <div class="form__row">
            <div class="form__field">
              <label class="form__label" for="cf-firstname" data-i18n="contact.label.firstname">Prénom</label>
              <input
                class="form__input"
                type="text"
                id="cf-firstname"
                name="firstname"
                placeholder="Marie"
                data-i18n-placeholder="contact.ph.firstname"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="form__field">
              <label class="form__label" for="cf-lastname" data-i18n="contact.label.lastname">Nom</label>
              <input
                class="form__input"
                type="text"
                id="cf-lastname"
                name="lastname"
                placeholder="Dupont"
                data-i18n-placeholder="contact.ph.lastname"
                required
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="form__row">
            <div class="form__field">
              <label class="form__label" for="cf-email" data-i18n="contact.label.email">Email professionnel</label>
              <input
                class="form__input"
                type="email"
                id="cf-email"
                name="email"
                placeholder="marie.dupont@entreprise.fr"
                data-i18n-placeholder="contact.ph.email"
                required
                autocomplete="email"
              />
            </div>
            <div class="form__field">
              <label class="form__label" for="cf-phone" data-i18n="contact.label.phone">Téléphone</label>
              <input
                class="form__input"
                type="tel"
                id="cf-phone"
                name="phone"
                placeholder="+33 6 12 34 56 78"
                data-i18n-placeholder="contact.ph.phone"
                autocomplete="tel"
              />
            </div>
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-company" data-i18n="contact.label.company">Société</label>
            <input
              class="form__input"
              type="text"
              id="cf-company"
              name="company"
              placeholder="Tourisme Pro SAS"
              data-i18n-placeholder="contact.ph.company"
              autocomplete="organization"
            />
          </div>

          <div class="form__row form__row--trial" data-trial-fields hidden>
            <div class="form__field">
              <label class="form__label" for="cf-role" data-i18n="contact.label.role">Rôle dans l'entreprise</label>
              <select class="form__select" id="cf-role" name="role" autocomplete="organization-title">
                <option value="" disabled selected data-i18n="contact.role.select">Choisir un rôle…</option>
                <option value="sales_rep" data-i18n="contact.role.sales_rep">Commercial terrain</option>
                <option value="sales_manager" data-i18n="contact.role.sales_manager">Responsable commercial</option>
                <option value="head_of_sales" data-i18n="contact.role.head_of_sales">Directeur commercial</option>
                <option value="sales_ops" data-i18n="contact.role.sales_ops">Sales Ops / RevOps</option>
                <option value="founder_ceo" data-i18n="contact.role.founder_ceo">Fondateur / CEO</option>
                <option value="other" data-i18n="contact.role.other">Autre</option>
              </select>
            </div>
            <div class="form__field">
              <label class="form__label" for="cf-users" data-i18n="contact.label.users">Nombre d'utilisateurs potentiels</label>
              <input
                class="form__input"
                type="number"
                id="cf-users"
                name="users_count"
                min="1"
                inputmode="numeric"
                placeholder="8"
                data-i18n-placeholder="contact.ph.users"
              />
            </div>
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-subject" data-i18n="contact.label.subject">Sujet</label>
            <select class="form__select" id="cf-subject" name="subject" required>
              <option value="" disabled selected data-i18n="contact.opt.select">Choisir un sujet…</option>
              <option value="trial" data-i18n="contact.opt.trial">Essai gratuit / Try for free</option>
              <option value="demo" data-i18n="contact.opt.demo">Demande de démo</option>
              <option value="team" data-i18n="contact.opt.team">Déploiement équipe / Hub</option>
              <option value="partnership" data-i18n="contact.opt.partnership">Partenariat & intégration</option>
              <option value="sector" data-i18n="contact.opt.sector">Nouveau secteur</option>
              <option value="support" data-i18n="contact.opt.support">Support technique</option>
              <option value="other" data-i18n="contact.opt.other">Autre</option>
            </select>
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-message" data-i18n="contact.label.message">Message</label>
            <textarea
              class="form__textarea"
              id="cf-message"
              name="message"
              placeholder="Décrivez votre contexte, votre équipe, vos questions…"
              data-i18n-placeholder="contact.ph.message"
              required
            ></textarea>
          </div>

          <button class="btn btn--primary form__submit" type="submit" id="cf-submit" data-i18n="contact.form.submit">
            Envoyer le message →
          </button>

          <div class="form__feedback form__feedback--success" id="cf-success" role="alert" data-i18n="contact.form.success">
            ✓ Message envoyé ! On vous répond sous 24h ouvrées.
          </div>
          <div class="form__feedback form__feedback--error" id="cf-error" role="alert" data-i18n="contact.form.error">
            Une erreur est survenue. Veuillez réessayer ou écrire à contact@reedly.ai
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('cf-success');
  const errorEl = document.getElementById('cf-error');
  const subjectSel = document.getElementById('cf-subject') as HTMLSelectElement | null;
  const messageEl = document.getElementById('cf-message') as HTMLTextAreaElement | null;
  const roleEl = document.getElementById('cf-role') as HTMLInputElement | null;
  const usersEl = document.getElementById('cf-users') as HTMLInputElement | null;
  const trialFields = document.querySelector('[data-trial-fields]') as HTMLElement | null;
  const ALLOWED_SUBJECTS = new Set(['trial', 'demo', 'team', 'partnership', 'sector', 'support', 'other']);
  let hasTrackedFormStart = false;

  const applySubjectMode = (subject: string | null) => {
    const isTrial = subject === 'trial';
    if (trialFields) {
      if (isTrial) trialFields.removeAttribute('hidden');
      else trialFields.setAttribute('hidden', '');
    }
    if (roleEl) roleEl.required = isTrial;
    if (usersEl) usersEl.required = isTrial;
    if (messageEl) messageEl.required = !isTrial;
    if (successEl) {
      const key = isTrial ? 'contact.form.success.trial' : 'contact.form.success';
      successEl.setAttribute('data-i18n', key);
      const value = (window as any)._reedlyT?.[document.documentElement.lang || 'fr']?.[key];
      if (value) successEl.textContent = value;
    }
  };

  subjectSel?.addEventListener('change', () => applySubjectMode(subjectSel.value));

  const activateTrial = () => {
    if (!subjectSel) return;
    subjectSel.value = 'trial';
    applySubjectMode('trial');
    const target = document.getElementById('trial') || form;
    target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => {
      (document.getElementById('cf-firstname') as HTMLInputElement | null)?.focus({ preventScroll: true });
    }, 500);
  };

  const openTrialFromHash = () => {
    if (window.location.hash !== '#trial') return;
    activateTrial();
  };

  applySubjectMode(subjectSel?.value || null);
  openTrialFromHash();
  window.addEventListener('hashchange', openTrialFromHash);

  // Direct click handlers on any in-page link targeting #trial, so same-page clicks
  // always activate the mode even when the hash is already set.
  document.addEventListener('click', (e) => {
    const el = e.target as HTMLElement | null;
    const link = el?.closest?.('a[href$="#trial"]') as HTMLAnchorElement | null;
    if (!link) return;
    // Only intercept clicks that stay on the current page
    try {
      const url = new URL(link.href, window.location.href);
      if (url.origin !== window.location.origin) return;
      if (url.pathname.replace(/\/$/, '') !== window.location.pathname.replace(/\/$/, '')) return;
    } catch {
      return;
    }
    e.preventDefault();
    if (window.location.hash !== '#trial') {
      history.replaceState(null, '', '#trial');
    }
    activateTrial();
  });

  const t = (key: string): string => {
    const lang = document.documentElement.lang || 'fr';
    return (window as any)._reedlyT?.[lang]?.[key] ?? key;
  };

  const track = (eventName: string, props: Record<string, unknown> = {}) => {
    const externalTracker = (window as any).reedlyTrackEvent;
    if (typeof externalTracker === 'function') {
      externalTracker(eventName, props);
      return;
    }

    try {
      const posthog = (window as any).posthog;
      if (posthog && typeof posthog.capture === 'function') {
        posthog.capture(eventName, props);
      }
    } catch (err) {
      console.error('[tracking] capture error:', err);
    }
  };

  const normalizeSubject = (value: unknown): string => {
    if (typeof value !== 'string') return 'unknown';
    return ALLOWED_SUBJECTS.has(value) ? value : 'unknown';
  };

  const getMessageLengthBucket = (value: unknown): string => {
    const len = typeof value === 'string' ? value.trim().length : 0;
    if (len <= 50) return '0_50';
    if (len <= 200) return '51_200';
    if (len <= 500) return '201_500';
    return '500_plus';
  };

  const hasCompany = (value: unknown): boolean =>
    typeof value === 'string' && value.trim().length > 0;

  form?.addEventListener('focusin', () => {
    if (hasTrackedFormStart) return;
    hasTrackedFormStart = true;
    track('landing_contact_form_started', {
      form_id: 'contact_form',
      entry_point: window.location.hash === '#contact' ? 'anchor_navigation' : 'direct',
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    // Hide previous feedback
    successEl?.classList.remove('visible');
    errorEl?.classList.remove('visible');

    // Disable button
    submitBtn.disabled = true;
    submitBtn.textContent = t('contact.form.sending');

    const data = Object.fromEntries(new FormData(form));
    const subject = normalizeSubject(data.subject);
    const startedAt = performance.now();

    track('landing_contact_form_submitted', {
      form_id: 'contact_form',
      subject,
      has_company: hasCompany(data.company),
      message_length_bucket: getMessageLengthBucket(data.message),
    });

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        track('landing_contact_form_succeeded', {
          form_id: 'contact_form',
          subject,
          request_duration_ms: Math.round(performance.now() - startedAt),
        });
        successEl?.classList.add('visible');
        form.reset();
        hasTrackedFormStart = false;
      } else {
        const body = await res.json().catch(() => ({}));
        console.error('Contact form error:', body);
        const errorType = res.status >= 500 ? 'server' : res.status >= 400 ? 'validation' : 'unknown';
        track('landing_contact_form_failed', {
          form_id: 'contact_form',
          subject,
          error_type: errorType,
          http_status: res.status,
        });
        errorEl?.classList.add('visible');
      }
    } catch (err) {
      console.error('Contact form network error:', err);
      track('landing_contact_form_failed', {
        form_id: 'contact_form',
        subject,
        error_type: 'network',
        http_status: null,
      });
      errorEl?.classList.add('visible');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = t('contact.form.submit');
    }
  });
</script>
