---
// Contact — form section with Resend integration
---

<section class="section section--alt" id="contact">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow">Contact</div>
      <h2>Une question ?<br /><em>On vous répond.</em></h2>
      <p class="section__lead">
        Démonstration, partenariat, retour terrain ou simple curiosité — écrivez-nous,
        on répond sous 24h.
      </p>
    </div>

    <div class="contact__grid">
      <!-- Left: context -->
      <div class="contact__info reveal">
        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M15 10l4.553-2.069A1 1 0 0121 8.87V15.13a1 1 0 01-1.447.9L15 14M3 8h12a2 2 0 012 2v4a2 2 0 01-2 2H3a2 2 0 01-2-2v-4a2 2 0 012-2z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4>Demande de démo</h4>
            <p>Vous voulez voir Reedly en action ? On vous montre une session live de 20 min.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4>Déploiement équipe</h4>
            <p>Vous pilotez une équipe de commerciaux ? On vous accompagne pour l'onboarding.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4>Partenariat & intégration</h4>
            <p>CRM, outil commercial, API — discutons d'une intégration sur mesure.</p>
          </div>
        </div>

        <div class="contact__feature">
          <div class="contact__feature-icon">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="contact__feature-text">
            <h4>contact@reedly.ai</h4>
            <p>Réponse garantie sous 24h ouvrées.</p>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="contact__form-card reveal">
        <form id="contact-form" novalidate>
          <div class="form__row">
            <div class="form__field">
              <label class="form__label" for="cf-firstname">Prénom</label>
              <input
                class="form__input"
                type="text"
                id="cf-firstname"
                name="firstname"
                placeholder="Marie"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="form__field">
              <label class="form__label" for="cf-lastname">Nom</label>
              <input
                class="form__input"
                type="text"
                id="cf-lastname"
                name="lastname"
                placeholder="Dupont"
                required
                autocomplete="family-name"
              />
            </div>
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-email">Email professionnel</label>
            <input
              class="form__input"
              type="email"
              id="cf-email"
              name="email"
              placeholder="marie.dupont@entreprise.fr"
              required
              autocomplete="email"
            />
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-company">Société</label>
            <input
              class="form__input"
              type="text"
              id="cf-company"
              name="company"
              placeholder="Tourisme Pro SAS"
              autocomplete="organization"
            />
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-subject">Sujet</label>
            <select class="form__select" id="cf-subject" name="subject" required>
              <option value="" disabled selected>Choisir un sujet…</option>
              <option value="demo">Demande de démo</option>
              <option value="team">Déploiement équipe / Hub</option>
              <option value="partnership">Partenariat & intégration</option>
              <option value="sector">Nouveau secteur</option>
              <option value="support">Support technique</option>
              <option value="other">Autre</option>
            </select>
          </div>

          <div class="form__field">
            <label class="form__label" for="cf-message">Message</label>
            <textarea
              class="form__textarea"
              id="cf-message"
              name="message"
              placeholder="Décrivez votre contexte, votre équipe, vos questions…"
              required
            ></textarea>
          </div>

          <button class="btn btn--primary form__submit" type="submit" id="cf-submit">
            Envoyer le message →
          </button>

          <div class="form__feedback form__feedback--success" id="cf-success" role="alert">
            ✓ Message envoyé ! On vous répond sous 24h ouvrées.
          </div>
          <div class="form__feedback form__feedback--error" id="cf-error" role="alert">
            Une erreur est survenue. Veuillez réessayer ou écrire à contact@reedly.ai
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('cf-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('cf-success');
  const errorEl = document.getElementById('cf-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    // Hide previous feedback
    successEl?.classList.remove('visible');
    errorEl?.classList.remove('visible');

    // Disable button
    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi en cours…';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        successEl?.classList.add('visible');
        form.reset();
      } else {
        const body = await res.json().catch(() => ({}));
        console.error('Contact form error:', body);
        errorEl?.classList.add('visible');
      }
    } catch (err) {
      console.error('Contact form network error:', err);
      errorEl?.classList.add('visible');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Envoyer le message →';
    }
  });
</script>
