---
interface Props {
  title: string;
  text: string;
}
const { title, text } = Astro.props;
---

<section class="section">
  <div class="inner">
    <div class="alt-verdict reveal">
      <h2 set:html={title} />
      <p>{text}</p>
    </div>
  </div>
</section>

<style>
  .alt-verdict {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .alt-verdict p {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-top: 14px;
  }
</style>
