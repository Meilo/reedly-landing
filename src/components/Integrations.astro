---
// Integrations, meetsponsors-style ecosystem wall: Reedly sits centre-stage as
// the focal card, with the tools it connects to drifting around it in two slow
// marquee rows (opposite directions), edges faded, a pinstripe + green glow
// behind the centre. Reproduces the reference effect for the CRM/integrations
// block.

const tilesA = [
  { name: 'HubSpot', img: '/integration/hubspot.png' },
  { name: 'Salesforce', img: '/integration/salesforce.png' },
  { name: 'Slack', img: '/integration/slack.png' },
  { name: 'Discord', img: '/integration/discord.png' },
  { name: 'API', braces: true },
];
// row B: a rotated order so the two rows don't move in lockstep
const tilesB = [tilesA[2], tilesA[4], tilesA[0], tilesA[3], tilesA[1]];

// Repeat each set 4× per row. The track then holds two identical halves, each
// wider than the viewport, so translateX(-50%) always lands on an identical
// frame with no empty edge, a truly seamless infinite loop.
const rowA = [...tilesA, ...tilesA, ...tilesA, ...tilesA];
const rowB = [...tilesB, ...tilesB, ...tilesB, ...tilesB];
---

<section class="section integrations" id="integrations">
  <div class="inner">
    <header class="int-head reveal">
      <div class="section__eyebrow" data-i18n="integrations.eyebrow">Intégrations</div>
      <h2 data-i18n-html="integrations.title">
        Branchez Reedly à<br /><em>votre stack.</em>
      </h2>
      <p class="section__lead" data-i18n="integrations.lead">
        Vos rapports atterrissent là où votre équipe travaille déjà : canaux
        d'équipe, fiches CRM, alertes managers. Aucun copier-coller.
      </p>
    </header>

    <!-- ── Ecosystem stage: drifting wall + centred focal card ── -->
    <div class="int-stage reveal">
      <div class="int-marquee" aria-hidden="true">
        <div class="int-row">
          <div class="int-track">
            {rowA.map((t) => (
              <div class="int-tile">
                <span class="int-tile__logo">
                  {t.braces ? (
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 4H7a2 2 0 0 0-2 2v3a2 2 0 0 1-2 2 2 2 0 0 1 2 2v3a2 2 0 0 0 2 2h1" />
                      <path d="M16 4h1a2 2 0 0 1 2 2v3a2 2 0 0 0 2 2 2 2 0 0 0-2 2v3a2 2 0 0 1-2 2h-1" />
                    </svg>
                  ) : (
                    <img src={t.img} alt={t.name} loading="lazy" decoding="async" width="30" height="30" />
                  )}
                </span>
                <span class="int-tile__name">{t.name}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="int-row">
          <div class="int-track int-track--rev">
            {rowB.map((t) => (
              <div class="int-tile">
                <span class="int-tile__logo">
                  {t.braces ? (
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M8 4H7a2 2 0 0 0-2 2v3a2 2 0 0 1-2 2 2 2 0 0 1 2 2v3a2 2 0 0 0 2 2h1" />
                      <path d="M16 4h1a2 2 0 0 1 2 2v3a2 2 0 0 0 2 2 2 2 0 0 0-2 2v3a2 2 0 0 1-2 2h-1" />
                    </svg>
                  ) : (
                    <img src={t.img} alt={t.name} loading="lazy" decoding="async" width="30" height="30" />
                  )}
                </span>
                <span class="int-tile__name">{t.name}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- centred focal card -->
      <div class="int-hero">
        <span class="int-hero__grid" aria-hidden="true"></span>
        <div class="int-hero__card">
          <span class="int-hero__mark">
            <img src="/favicon.png" alt="Reedly" width="44" height="44" />
          </span>
          <span class="int-hero__name">Reedly</span>
          <span class="int-hero__tagline" data-i18n="integrations.hub.tagline">
            Vos rapports, dans tous vos outils.
          </span>
          <span class="int-hero__badge" data-i18n="integrations.hub.badge">
            Sans copier-coller
          </span>
        </div>
      </div>
    </div>

    <!-- ── Custom integration ── -->
    <a
      class="int-custom reveal"
      href="#contact"
      data-track-id="integrations_custom"
      data-track-section="integrations"
    >
      <span class="int-custom__logo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="26" height="26" aria-hidden="true">
          <rect x="3" y="3" width="7" height="9" rx="1.5" />
          <rect x="14" y="3" width="7" height="5" rx="1.5" />
          <rect x="14" y="12" width="7" height="9" rx="1.5" />
          <rect x="3" y="16" width="7" height="5" rx="1.5" />
        </svg>
        <span class="int-custom__badge" aria-hidden="true">+</span>
      </span>
      <span class="int-custom__body">
        <span class="int-custom__name" data-i18n="integrations.custom.name">Votre outil</span>
        <span class="int-custom__desc" data-i18n="integrations.custom.desc">
          CRM maison, dashboard interne, API privée : branchez ce que vous voulez via notre API.
        </span>
      </span>
      <span class="int-custom__cta" data-i18n="integrations.custom.cta">Discutons-en →</span>
    </a>
  </div>
</section>

<style>
  .integrations {
    position: relative;
    overflow: hidden;
  }

  .integrations::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 60% at 50% 50%,
      rgba(22, 163, 74, 0.05) 0%,
      transparent 64%
    );
    pointer-events: none;
    z-index: 0;
  }

  .integrations .inner {
    position: relative;
    z-index: 1;
  }

  .int-head {
    max-width: 640px;
  }

  /* ── Stage ── */
  .int-stage {
    position: relative;
    margin-top: 44px;
    height: 320px;
    overflow: hidden;
  }

  /* ── Drifting wall ── */
  .int-marquee {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
    z-index: 1;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 16%,
      #000 84%,
      transparent 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0%,
      #000 16%,
      #000 84%,
      transparent 100%
    );
  }

  .int-row {
    display: flex;
    overflow: hidden;
  }

  .int-track {
    display: flex;
    gap: 16px;
    width: max-content;
    padding-right: 16px; /* keeps gap consistent at the seam */
    animation: int-scroll 80s linear infinite;
    will-change: transform;
  }
  .int-track--rev {
    animation-duration: 100s;
    animation-direction: reverse;
  }

  @keyframes int-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ── Tile (logo chip) ── */
  .int-tile {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 13px;
    padding: 13px 22px 13px 13px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.32);
    white-space: nowrap;
  }

  .int-tile__logo {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.05), transparent 60%),
      rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border);
    color: var(--green);
  }
  .int-tile__logo img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .int-tile__name {
    font-family: var(--display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  /* ── Centred focal card ── */
  .int-hero {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .int-hero::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 420px;
    height: 420px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(22, 163, 74, 0.32), transparent 60%);
    z-index: -2;
    pointer-events: none;
  }

  /* pinstripe texture behind the card */
  .int-hero__grid {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 340px;
    height: 340px;
    transform: translate(-50%, -50%);
    border-radius: 34px;
    background-image: repeating-linear-gradient(
      90deg,
      rgba(34, 197, 94, 0.2) 0,
      rgba(34, 197, 94, 0.2) 1px,
      transparent 1px,
      transparent 10px
    );
    -webkit-mask-image: radial-gradient(circle at 50% 50%, #000 26%, transparent 70%);
    mask-image: radial-gradient(circle at 50% 50%, #000 26%, transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .int-hero__card {
    position: relative;
    width: 268px;
    padding: 30px 28px;
    border-radius: 26px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
    background: linear-gradient(180deg, #16233c 0%, #0e1a2c 100%);
    border: 1px solid rgba(34, 197, 94, 0.4);
    box-shadow:
      0 0 0 1px rgba(34, 197, 94, 0.08),
      0 30px 80px rgba(0, 0, 0, 0.55),
      0 0 64px rgba(22, 163, 74, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .int-hero__mark {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    overflow: hidden;
    display: grid;
    place-items: center;
    box-shadow: 0 0 28px rgba(34, 197, 94, 0.5);
  }
  .int-hero__mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }

  .int-hero__name {
    font-family: var(--display);
    font-size: 1.55rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1;
  }

  .int-hero__tagline {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--muted);
    max-width: 20ch;
  }

  .int-hero__badge {
    margin-top: 2px;
    font-family: var(--mono);
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.28);
    padding: 5px 12px;
    border-radius: 999px;
  }

  /* ── Custom integration card ── */
  .int-custom {
    margin: 28px auto 0;
    max-width: 620px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 16px 22px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px dashed rgba(148, 163, 184, 0.38);
    box-shadow: 0 8px 26px rgba(0, 0, 0, 0.3);
    text-decoration: none;
    color: var(--text);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .int-custom:hover {
    transform: translateY(-2px);
    border-style: solid;
    border-color: rgba(34, 197, 94, 0.45);
    box-shadow: 0 16px 40px rgba(22, 163, 74, 0.16);
  }

  .int-custom__logo {
    position: relative;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    color: var(--muted);
    border: 1px dashed rgba(148, 163, 184, 0.5);
    background: rgba(255, 255, 255, 0.02);
    transition: color 0.3s ease, border-color 0.3s ease;
  }
  .int-custom:hover .int-custom__logo {
    color: var(--green);
    border-color: rgba(34, 197, 94, 0.55);
  }

  .int-custom__badge {
    position: absolute;
    top: -6px;
    right: -6px;
    width: 19px;
    height: 19px;
    border-radius: 50%;
    background: var(--green);
    color: #052010;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.78rem;
    display: grid;
    place-items: center;
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.55);
  }

  .int-custom__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }

  .int-custom__name {
    font-family: var(--display);
    font-size: 1.06rem;
    font-weight: 600;
    line-height: 1.15;
    color: var(--text);
  }

  .int-custom__desc {
    font-size: 0.84rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .int-custom__cta {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    font-weight: 600;
  }

  /* ── Tablet ── */
  @media (max-width: 880px) {
    .int-stage {
      height: 300px;
      margin-top: 36px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 560px) {
    .int-stage {
      height: 260px;
    }
    .int-marquee { gap: 14px; }
    .int-tile {
      padding: 11px 18px 11px 11px;
      gap: 11px;
    }
    .int-tile__logo { width: 38px; height: 38px; border-radius: 10px; }
    .int-tile__logo img { width: 24px; height: 24px; }
    .int-tile__name { font-size: 0.92rem; }

    .int-hero__card {
      width: 224px;
      padding: 24px 22px;
      border-radius: 22px;
    }
    .int-hero__grid { width: 280px; height: 280px; }
    .int-hero::before { width: 340px; height: 340px; }
    .int-hero__name { font-size: 1.35rem; }
    .int-hero__tagline { font-size: 0.86rem; }

    .int-custom {
      grid-template-columns: auto 1fr;
      padding: 14px 16px;
    }
    .int-custom__cta {
      grid-column: 1 / -1;
      padding-top: 2px;
    }
  }

  /* ── Light mode ── */
  :global(html[data-theme="light"]) .integrations::before {
    background: radial-gradient(
      ellipse 55% 60% at 50% 50%,
      rgba(22, 163, 74, 0.04) 0%,
      transparent 64%
    );
  }
  :global(html[data-theme="light"]) .int-tile {
    background: #ffffff;
    border-color: rgba(148, 163, 184, 0.32);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
  }
  :global(html[data-theme="light"]) .int-tile__logo {
    background: #f8fafc;
    border-color: rgba(148, 163, 184, 0.3);
  }
  :global(html[data-theme="light"]) .int-hero__card {
    background: linear-gradient(180deg, #ffffff 0%, #f4f7fb 100%);
    border-color: rgba(22, 163, 74, 0.32);
    box-shadow:
      0 0 0 1px rgba(22, 163, 74, 0.06),
      0 30px 70px rgba(15, 23, 42, 0.16),
      0 0 60px rgba(22, 163, 74, 0.18);
  }
  :global(html[data-theme="light"]) .int-hero__name {
    color: #0f172a;
  }
  :global(html[data-theme="light"]) .int-hero__grid {
    background-image: repeating-linear-gradient(
      90deg,
      rgba(22, 163, 74, 0.22) 0,
      rgba(22, 163, 74, 0.22) 1px,
      transparent 1px,
      transparent 10px
    );
  }
  :global(html[data-theme="light"]) .int-hero::before {
    background: radial-gradient(circle, rgba(22, 163, 74, 0.2), transparent 60%);
  }
  :global(html[data-theme="light"]) .int-custom {
    background: #ffffff;
    border-color: rgba(15, 23, 42, 0.22);
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.07);
  }
  :global(html[data-theme="light"]) .int-custom__logo {
    background: #f8fafc;
    border-color: rgba(15, 23, 42, 0.24);
  }

  /* ── Reduced motion: freeze the wall ── */
  @media (prefers-reduced-motion: reduce) {
    .int-track {
      animation: none;
      transform: translateX(-12%);
    }
  }
</style>
