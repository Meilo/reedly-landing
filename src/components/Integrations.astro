---
// Integrations — orbital signal hub showing connections between Reedly and
// messaging tools (Slack, Discord) + CRMs (HubSpot, Salesforce).
---

<section class="section integrations" id="integrations">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow" data-i18n="integrations.eyebrow">Écosystème</div>
      <h2 data-i18n-html="integrations.title">
        Branchez Reedly à<br /><em>votre stack.</em>
      </h2>
      <p class="section__lead" data-i18n="integrations.lead">
        Vos rapports atterrissent là où votre équipe travaille déjà — canaux
        d'équipe, fiches CRM, alertes managers. Aucun copier-coller.
      </p>
    </div>

    <!-- ── Constellation ── -->
    <div class="orbit reveal" aria-hidden="false">
      <!-- Decorative concentric rings -->
      <div class="orbit__ring orbit__ring--1"></div>
      <div class="orbit__ring orbit__ring--2"></div>
      <div class="orbit__ring orbit__ring--3"></div>

      <!-- SVG connection lines (extends 120px below orbit to reach custom card) -->
      <svg
        class="orbit__svg"
        viewBox="0 0 1000 720"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        <defs>
          <linearGradient id="lineLeft" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(34,197,94,0.05)" />
            <stop offset="100%" stop-color="rgba(34,197,94,0.55)" />
          </linearGradient>
          <linearGradient id="lineRight" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="rgba(34,197,94,0.55)" />
            <stop offset="100%" stop-color="rgba(34,197,94,0.05)" />
          </linearGradient>
          <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="rgba(34,197,94,0.35)" />
            <stop offset="100%" stop-color="rgba(34,197,94,0)" />
          </radialGradient>
          <filter id="softGlow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="3" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>

        <!-- Center halo -->
        <circle cx="500" cy="300" r="180" fill="url(#nodeGlow)" />

        <!-- Connection paths: center → HubSpot (top-left) -->
        <path
          id="path-hub"
          class="orbit__line orbit__line--out"
          d="M 500 300 Q 320 200 130 130"
          fill="none"
          stroke="url(#lineRight)"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <!-- center → Salesforce (bottom-left) -->
        <path
          id="path-sf"
          class="orbit__line orbit__line--out"
          d="M 500 300 Q 320 400 130 470"
          fill="none"
          stroke="url(#lineRight)"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <!-- Slack (top-right) ← center -->
        <path
          id="path-slack"
          class="orbit__line orbit__line--out"
          d="M 500 300 Q 680 200 870 130"
          fill="none"
          stroke="url(#lineRight)"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <!-- Discord (bottom-right) ← center -->
        <path
          id="path-discord"
          class="orbit__line orbit__line--out"
          d="M 500 300 Q 680 400 870 470"
          fill="none"
          stroke="url(#lineRight)"
          stroke-width="1.5"
          stroke-linecap="round"
        />
        <!-- center → Custom (extends below orbit edge into the custom card) -->
        <path
          id="path-custom"
          class="orbit__line orbit__line--out orbit__line--custom"
          d="M 500 300 L 500 700"
          fill="none"
          stroke="rgba(148, 163, 184, 0.55)"
          stroke-width="1.5"
          stroke-linecap="round"
        />

        <!-- Flowing particles along each path -->
        <circle r="3.5" fill="#22c55e" filter="url(#softGlow)">
          <animateMotion dur="3.4s" repeatCount="indefinite" rotate="auto">
            <mpath href="#path-hub" />
          </animateMotion>
        </circle>
        <circle r="3.5" fill="#22c55e" filter="url(#softGlow)">
          <animateMotion dur="3.8s" repeatCount="indefinite" rotate="auto" begin="0.6s">
            <mpath href="#path-sf" />
          </animateMotion>
        </circle>
        <circle r="3.5" fill="#22c55e" filter="url(#softGlow)">
          <animateMotion dur="3.2s" repeatCount="indefinite" rotate="auto" begin="0.3s">
            <mpath href="#path-slack" />
          </animateMotion>
        </circle>
        <circle r="3.5" fill="#22c55e" filter="url(#softGlow)">
          <animateMotion dur="4.0s" repeatCount="indefinite" rotate="auto" begin="1.1s">
            <mpath href="#path-discord" />
          </animateMotion>
        </circle>
        <circle r="3" fill="#94a3b8" filter="url(#softGlow)">
          <animateMotion dur="4.5s" repeatCount="indefinite" rotate="auto" begin="0.4s">
            <mpath href="#path-custom" />
          </animateMotion>
        </circle>
      </svg>

      <!-- Category labels -->
      <div class="orbit__cat orbit__cat--left" data-i18n="integrations.cat.crm">
        CRM
      </div>
      <div class="orbit__cat orbit__cat--right" data-i18n="integrations.cat.msg">
        Messagerie & communauté
      </div>

      <!-- ─── Center: Reedly ─── -->
      <div class="orbit__core">
        <div class="orbit__core-inner">
          <div class="orbit__core-mark">
            <img src="/favicon.png" alt="Reedly" width="44" height="44" />
          </div>
          <div class="orbit__core-name">REEDLY</div>
          <div class="orbit__core-meta" data-i18n="integrations.core.meta">
            Rapports terrain
          </div>
        </div>
        <span class="orbit__core-pulse"></span>
        <span class="orbit__core-pulse orbit__core-pulse--delay"></span>
      </div>

      <!-- ─── Nodes (4) ─── -->
      <!-- HubSpot — top-left -->
      <article class="orbit__node orbit__node--tl" data-cat="crm">
        <div class="orbit__node-shell">
          <img
            src="/integration/hubspot.png"
            alt="HubSpot"
            loading="lazy"
            decoding="async"
            width="40"
            height="40"
          />
        </div>
        <div class="orbit__node-card">
          <div class="orbit__node-tag" data-i18n="integrations.tag.crm">CRM</div>
          <div class="orbit__node-name">HubSpot</div>
          <div class="orbit__node-desc" data-i18n="integrations.hubspot.desc">
            Push automatique du rapport sur la fiche contact &amp; deal.
          </div>
        </div>
      </article>

      <!-- Salesforce — bottom-left -->
      <article class="orbit__node orbit__node--bl" data-cat="crm">
        <div class="orbit__node-shell">
          <img
            src="/integration/salesforce.png"
            alt="Salesforce"
            loading="lazy"
            decoding="async"
            width="40"
            height="40"
          />
        </div>
        <div class="orbit__node-card">
          <div class="orbit__node-tag" data-i18n="integrations.tag.crm">CRM</div>
          <div class="orbit__node-name">Salesforce</div>
          <div class="orbit__node-desc" data-i18n="integrations.salesforce.desc">
            Sync des engagements, prochaines étapes et opportunités.
          </div>
        </div>
      </article>

      <!-- Slack — top-right -->
      <article class="orbit__node orbit__node--tr" data-cat="msg">
        <div class="orbit__node-shell">
          <img
            src="/integration/slack.png"
            alt="Slack"
            loading="lazy"
            decoding="async"
            width="40"
            height="40"
          />
        </div>
        <div class="orbit__node-card">
          <div class="orbit__node-tag" data-i18n="integrations.tag.msg">Messagerie</div>
          <div class="orbit__node-name">Slack</div>
          <div class="orbit__node-desc" data-i18n="integrations.slack.desc">
            Notifie le canal d'équipe à chaque rapport généré.
          </div>
        </div>
      </article>

      <!-- Discord — bottom-right -->
      <article class="orbit__node orbit__node--br" data-cat="msg">
        <div class="orbit__node-shell">
          <img
            src="/integration/discord.png"
            alt="Discord"
            loading="lazy"
            decoding="async"
            width="40"
            height="40"
          />
        </div>
        <div class="orbit__node-card">
          <div class="orbit__node-tag" data-i18n="integrations.tag.msg">Communauté</div>
          <div class="orbit__node-name">Discord</div>
          <div class="orbit__node-desc" data-i18n="integrations.discord.desc">
            Diffusion des synthèses dans vos canaux Discord.
          </div>
        </div>
      </article>

    </div>

    <!-- ─── Custom integration extension ─── -->
    <div class="custom-band reveal">
      <a
        class="custom-card"
        href="#contact"
        data-track-id="integrations_custom"
        data-track-section="integrations"
      >
        <div class="custom-card__shell">
          <span class="custom-card__badge">+</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" width="36" height="36" aria-hidden="true">
            <rect x="3" y="3" width="7" height="9" rx="1.5" />
            <rect x="14" y="3" width="7" height="5" rx="1.5" />
            <rect x="14" y="12" width="7" height="9" rx="1.5" />
            <rect x="3" y="16" width="7" height="5" rx="1.5" />
          </svg>
        </div>
        <div class="custom-card__body">
          <div class="custom-card__tag" data-i18n="integrations.tag.custom">Sur mesure</div>
          <div class="custom-card__name" data-i18n="integrations.custom.name">Votre outil</div>
          <div class="custom-card__desc" data-i18n="integrations.custom.desc">
            CRM maison, dashboard interne, API privée — branchez ce que vous voulez via notre API.
          </div>
        </div>
        <span class="custom-card__cta" data-i18n="integrations.custom.cta">Discutons-en →</span>
      </a>
    </div>
  </div>
</section>

<style>
  .integrations {
    position: relative;
    overflow: hidden;
  }

  .integrations::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 60% 70% at 50% 50%,
        rgba(22, 163, 74, 0.06) 0%,
        transparent 65%
      );
    pointer-events: none;
    z-index: 0;
  }

  .integrations .inner {
    position: relative;
    z-index: 1;
  }

  /* ── Constellation container ── */
  .orbit {
    position: relative;
    margin-top: 56px;
    height: 600px;
    max-width: 1000px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Decorative rings */
  .orbit__ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 1px dashed rgba(34, 197, 94, 0.16);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .orbit__ring--1 {
    width: 240px;
    height: 240px;
    border-color: rgba(34, 197, 94, 0.28);
    animation: orbit-spin 36s linear infinite;
  }
  .orbit__ring--2 {
    width: 420px;
    height: 420px;
    animation: orbit-spin-rev 60s linear infinite;
  }
  .orbit__ring--3 {
    width: 620px;
    height: 620px;
    border-style: dotted;
    border-color: rgba(148, 163, 184, 0.12);
    animation: orbit-spin 90s linear infinite;
  }

  @keyframes orbit-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to   { transform: translate(-50%, -50%) rotate(360deg); }
  }
  @keyframes orbit-spin-rev {
    from { transform: translate(-50%, -50%) rotate(360deg); }
    to   { transform: translate(-50%, -50%) rotate(0deg); }
  }

  /* SVG connection layer (extends 120px below orbit to reach custom card) */
  .orbit__svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: calc(100% + 120px);
    pointer-events: none;
    z-index: 1;
    overflow: visible;
  }

  .orbit__line {
    stroke-dasharray: 6 8;
    animation: dash-flow 4s linear infinite;
  }
  .orbit__line--out {
    animation-direction: reverse;
  }
  .orbit__line--custom {
    stroke-dasharray: 4 7;
    animation-duration: 6s;
  }
  @keyframes dash-flow {
    to { stroke-dashoffset: -56; }
  }

  /* ── Category labels ── */
  .orbit__cat {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--faint);
    padding: 6px 0;
    z-index: 2;
    writing-mode: vertical-rl;
    text-orientation: sideways;
  }
  .orbit__cat--left {
    left: 6px;
    transform: translateY(-50%) rotate(180deg);
  }
  .orbit__cat--right {
    right: 6px;
  }

  /* ── Center: Reedly ── */
  .orbit__core {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 168px;
    height: 168px;
    z-index: 4;
  }

  .orbit__core-inner {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background:
      radial-gradient(circle at 30% 30%, rgba(34, 197, 94, 0.25), transparent 60%),
      linear-gradient(155deg, #0e1a2c 0%, #1a2640 100%);
    border: 1px solid rgba(34, 197, 94, 0.5);
    box-shadow:
      0 0 0 1px rgba(34, 197, 94, 0.12),
      0 0 60px rgba(22, 163, 74, 0.35),
      inset 0 0 30px rgba(22, 163, 74, 0.18);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    z-index: 2;
  }

  .orbit__core-mark {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    overflow: hidden;
    display: grid;
    place-items: center;
    box-shadow: 0 0 24px rgba(34, 197, 94, 0.5);
  }
  .orbit__core-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    display: block;
  }

  .orbit__core-name {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    color: var(--text);
    font-weight: 600;
    margin-top: 2px;
  }

  .orbit__core-meta {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green);
    opacity: 0.8;
  }

  .orbit__core-pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(34, 197, 94, 0.55);
    z-index: 1;
    animation: core-pulse 3s ease-out infinite;
  }
  .orbit__core-pulse--delay {
    animation-delay: 1.5s;
  }
  @keyframes core-pulse {
    0%   { transform: scale(1);    opacity: 0.7; }
    100% { transform: scale(1.6);  opacity: 0;   }
  }

  /* ── Integration nodes ── */
  .orbit__node {
    position: absolute;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 14px;
    width: 280px;
  }

  .orbit__node--tl { top: 80px;  left: 60px;  flex-direction: row; }
  .orbit__node--bl { bottom: 80px; left: 60px; flex-direction: row; }
  .orbit__node--tr { top: 80px;  right: 60px; flex-direction: row-reverse; text-align: right; }
  .orbit__node--br { bottom: 80px; right: 60px; flex-direction: row-reverse; text-align: right; }

  .orbit__node-shell {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 18px;
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.04), transparent 60%),
      var(--surface);
    border: 1px solid var(--border);
    display: grid;
    place-items: center;
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
    position: relative;
  }

  .orbit__node-shell::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.35), transparent 40%);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }

  .orbit__node-shell img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(0, 0, 0, 0.4));
  }

  .orbit__node-card {
    flex: 1;
    min-width: 0;
  }

  .orbit__node-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green);
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.22);
    padding: 3px 8px;
    border-radius: 999px;
    margin-bottom: 8px;
  }

  .orbit__node-name {
    font-family: var(--display);
    font-size: 1.45rem;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 4px;
  }

  .orbit__node-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .orbit__node:hover .orbit__node-shell {
    transform: translateY(-3px);
    border-color: rgba(34, 197, 94, 0.5);
    box-shadow:
      0 18px 50px rgba(22, 163, 74, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .orbit__node:hover .orbit__node-shell::after {
    opacity: 1;
  }

  /* ── Custom integration band ── */
  .custom-band {
    position: relative;
    margin: 16px auto 0;
    max-width: 560px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .custom-card {
    width: 100%;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 18px;
    padding: 18px 22px;
    border-radius: 18px;
    background:
      radial-gradient(circle at 20% 0%, rgba(34, 197, 94, 0.06), transparent 60%),
      var(--surface);
    border: 1px dashed rgba(148, 163, 184, 0.4);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    text-decoration: none;
    color: var(--text);
    position: relative;
    z-index: 2;
    transition: transform 0.3s ease, border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  }

  .custom-card:hover {
    transform: translateY(-2px);
    border-color: rgba(34, 197, 94, 0.5);
    border-style: solid;
    background:
      radial-gradient(circle at 20% 0%, rgba(34, 197, 94, 0.12), transparent 60%),
      var(--surface);
    box-shadow:
      0 18px 50px rgba(22, 163, 74, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .custom-card__shell {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 16px;
    border: 1px dashed rgba(148, 163, 184, 0.55);
    background:
      radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.04), transparent 60%),
      var(--surface);
    display: grid;
    place-items: center;
    color: var(--muted);
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .custom-card:hover .custom-card__shell {
    color: var(--green);
    border-color: rgba(34, 197, 94, 0.6);
  }

  .custom-card__badge {
    position: absolute;
    top: -7px;
    right: -7px;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--green);
    color: #052010;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.85rem;
    display: grid;
    place-items: center;
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.6);
  }

  .custom-card__body {
    min-width: 0;
  }

  .custom-card__tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    background: rgba(148, 163, 184, 0.08);
    border: 1px solid rgba(148, 163, 184, 0.25);
    padding: 3px 8px;
    border-radius: 999px;
    margin-bottom: 6px;
  }

  .custom-card__name {
    font-family: var(--display);
    font-size: 1.35rem;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 4px;
  }

  .custom-card__desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--muted);
  }

  .custom-card__cta {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--green);
    font-weight: 600;
    padding-left: 8px;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .orbit {
      height: 540px;
    }
    .orbit__node {
      width: 220px;
    }
    .orbit__node--tl { top: 60px; left: 20px; }
    .orbit__node--bl { bottom: 60px; left: 20px; }
    .orbit__node--tr { top: 60px; right: 20px; }
    .orbit__node--br { bottom: 60px; right: 20px; }
    .orbit__ring--3 { display: none; }
    .orbit__cat { font-size: 0.6rem; }
  }

  /* ── Mobile: stack vertically with pulse spine ── */
  @media (max-width: 720px) {
    .orbit {
      height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
      padding: 24px 0;
    }
    .orbit__svg,
    .orbit__ring,
    .orbit__cat {
      display: none;
    }
    .orbit__core {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 132px;
      height: 132px;
      order: 3;
      margin: 6px 0;
    }
    .orbit__core-mark { width: 36px; height: 36px; font-size: 1.25rem; }
    .orbit__core-name { font-size: 0.7rem; }
    .orbit__core-meta { font-size: 0.55rem; }

    .orbit__node {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      bottom: auto;
      width: 100%;
      max-width: 360px;
      flex-direction: row !important;
      text-align: left !important;
      padding: 14px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(19, 29, 48, 0.5);
    }
