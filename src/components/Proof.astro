---
// Proof section
---

<!-- ── Proof ── -->
      <section class="section section--alt">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="proof.eyebrow">Résultats concrets</div>
            <h2 data-i18n-html="proof.title">Ce que ça change<br /><em>en pratique.</em></h2>
          </div>
          <div class="proof-grid">
            <div class="proof-stat reveal reveal-delay-1">
              <div class="proof-stat__val">8×</div>
              <div class="proof-stat__label" data-i18n="proof.stat1">
                Plus rapide que la rédaction manuelle d'un compte-rendu terrain
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-2">
              <div class="proof-stat__val">100%</div>
              <div class="proof-stat__label" data-i18n="proof.stat2">
                Des points discutés capturés — objections, engagements, prochaines étapes
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-3">
              <div class="proof-stat__val">&lt; 2min</div>
              <div class="proof-stat__label" data-i18n="proof.stat3">
                Pour obtenir un rapport complet structuré après la fin de l'enregistrement
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-3">
              <div class="proof-stat__val">0</div>
              <div class="proof-stat__label" data-i18n="proof.stat4">
                Données audio conservées — l'audio est supprimé dès la génération terminée
              </div>
            </div>
          </div>
        </div>
      </section>
