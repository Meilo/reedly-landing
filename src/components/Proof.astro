---
// Proof section
---

<!-- ── Proof ── -->
      <section class="section section--alt" id="proof">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="proof.eyebrow">Résultats</div>
            <h2 data-i18n-html="proof.title">Ce que vous gagnez<br /><em>en pilotage.</em></h2>
          </div>
          <div class="proof-grid">
            <div class="proof-stat reveal reveal-delay-1">
              <div class="proof-stat__val">100%</div>
              <div class="proof-stat__label" data-i18n="proof.stat1">
                Des engagements clients capturés et tracés. Fini les promesses oubliées
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-2">
              <div class="proof-stat__val">8×</div>
              <div class="proof-stat__label" data-i18n="proof.stat2">
                Moins de temps passé en reporting par votre équipe, plus de temps en clientèle
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-3">
              <div class="proof-stat__val">&lt; 2min</div>
              <div class="proof-stat__label" data-i18n="proof.stat3">
                Entre la fin du rendez-vous et la remontée du rapport dans votre Hub
              </div>
            </div>
            <div class="proof-stat reveal reveal-delay-3">
              <div class="proof-stat__val">0</div>
              <div class="proof-stat__label" data-i18n="proof.stat4">
                Réunion de reporting hebdo nécessaire : la donnée terrain remonte en continu
              </div>
            </div>
          </div>
        </div>
      </section>
