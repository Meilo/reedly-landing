---
// FinalCta section
---

<!-- ── Final CTA ── -->
      <section class="final-cta" id="final-cta">
        <div class="inner">
          <div class="final-cta__box reveal">
            <div>
              <h2 data-i18n-html="cta.title">Chaque rendez-vous terrain<br /><em>mérite un vrai rapport.</em></h2>
              <p class="final-cta__sub" data-i18n="cta.sub">
                Téléchargez Reedly et générez votre premier rapport en moins de 5 minutes. Essai 7 jours gratuit, sans carte bancaire.
              </p>
            </div>
            <div class="final-cta__action">
              <div class="final-cta__stores">
                <a
                  class="store-badge"
                  href="#"
                  data-store="ios"
                  data-track-id="final_store_ios"
                  data-track-type="download"
                  data-track-section="final_cta"
                >
                  <svg viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.3 133.4-316.9 264.6-316.9 70.1 0 128.4 46.4 172.1 46.4 41.8 0 107.2-49.1 183.2-49.1 29.2 0 130.4 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
                    />
                  </svg>
                  <div class="store-badge__text">
                    <span class="store-badge__sub" data-i18n="cta.store_sub">Disponible sur</span>
                    <span class="store-badge__name">App Store</span>
                  </div>
                </a>
                <a
                  class="store-badge"
                  href="#"
                  data-store="android"
                  data-track-id="final_store_android"
                  data-track-type="download"
                  data-track-section="final_cta"
                >
                  <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
                    <path
                      d="M48 59.49v393a4.33 4.33 0 007.37 3.07l232-233.5a4.33 4.33 0 000-6.14L55.37 56.42A4.33 4.33 0 0048 59.49zM400.35 256.28l-75.5 76.07-30.85-30.85c-1.57-1.57-4.12-1.57-5.69 0-1.57 1.57-1.57 4.12 0 5.69l33.7 33.7a4.02 4.02 0 005.69 0l78.35-78.93V256c0-1.96-1.57-4.12-3.53-5.69z"
                    />
                    <path
                      d="M400.35 256.28l-12.23 12.23c-1.57 1.57-4.12 1.57-5.69 0l-26.84-26.84c-1.57-1.57-1.57-4.12 0-5.69l44.76-45.13V256c0 .1 0 .19-.01.28zM260.61 285.14L55.37 452.56A4.29 4.29 0 0148 449.49V62.57z"
                    />
                  </svg>
                  <div class="store-badge__text">
                    <span class="store-badge__sub" data-i18n="cta.store_sub">Disponible sur</span>
                    <span class="store-badge__name">Google Play</span>
                  </div>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

<!-- ── Notify modal ── -->
<div class="notify-modal" id="notify-modal" aria-hidden="true">
  <div class="notify-modal__backdrop" id="notify-modal-backdrop"></div>
  <div class="notify-modal__dialog">
    <button class="notify-modal__close" id="notify-modal-close" type="button" aria-label="Fermer">&times;</button>
    <h3 class="notify-modal__title" data-i18n="notify.title">Bientôt disponible</h3>
    <p class="notify-modal__text" data-i18n="notify.text">
      L'application n'est pas encore sur les stores. Laissez votre email pour être prévenu(e) dès sa sortie.
    </p>
    <form class="notify-modal__form" id="notify-form">
      <input
        class="notify-modal__input"
        type="email"
        id="notify-email"
        required
        data-i18n-placeholder="notify.placeholder"
        placeholder="votre@email.com"
      />
      <button class="btn btn--primary btn--md notify-modal__submit" type="submit">
        <span data-i18n="notify.cta">Me prévenir</span>
      </button>
    </form>
    <div class="notify-modal__feedback" id="notify-feedback"></div>
  </div>
</div>

<!-- ── Android QR modal ── -->
