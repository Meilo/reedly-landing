---
// FinalCta section, closing "book a demo" band (stores moved to the footer).
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const bookHref = `/${lang}#rdv`;
const demoHref = `/${lang}#demo`;
---

<!-- ── Final CTA ── -->
      <section class="final-cta" id="final-cta">
        <div class="inner">
          <div class="final-cta__box reveal">
            <div>
              <h2 data-i18n-html="cta.title">[Titre CTA final à valider]</h2>
              <p class="final-cta__sub" data-i18n="cta.sub">
                [Sous-titre CTA final orienté direction à valider.]
              </p>
            </div>
            <div class="final-cta__action">
              <a
                class="btn btn--primary btn--lg"
                href={bookHref}
                data-link-fr="/fr#rdv"
                data-link-en="/en#rdv"
                data-i18n="cta.book_demo"
                data-track-id="final_book_demo"
                data-track-type="demo"
                data-track-section="final_cta"
                >Réserver une démo</a
              >
              <a
                class="btn btn--ghost btn--lg"
                href={demoHref}
                data-link-fr="/fr#demo"
                data-link-en="/en#demo"
                data-i18n="hero.see_demo"
                data-track-id="final_see_demo"
                data-track-type="demo"
                data-track-section="final_cta"
                >Voir la démo interactive</a
              >
            </div>
          </div>
        </div>

        <style>
          .final-cta__action {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
          }
        </style>
      </section>
