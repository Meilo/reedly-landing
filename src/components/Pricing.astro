---
// Pricing section
---

<!-- ── Pricing ── -->
      <section class="section" id="pricing">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
            <h2 data-i18n-html="pricing.title">
              Un tarif pour chaque<br /><em>profil terrain.</em>
            </h2>
            <p class="section__lead" data-i18n="pricing.lead">
              Que vous soyez commercial indépendant ou responsable d'une équipe, Reedly a un plan pour vous.
            </p>
          </div>

          <!-- Toggle -->
          <div class="pricing-toggle-wrap reveal">
            <div class="pricing-toggle" id="pricing-toggle">
              <button class="pricing-toggle__btn pricing-toggle__btn--active" data-panel="mobile" data-i18n="pricing.toggle.mobile" type="button">Commerciaux solo</button>
              <button class="pricing-toggle__btn" data-panel="managers" data-i18n="pricing.toggle.managers" type="button">Managers / Équipes</button>
            </div>
            <div class="pricing-billing-toggle" id="pricing-billing-toggle">
              <button class="pricing-billing-toggle__btn pricing-billing-toggle__btn--active" data-billing="monthly" data-i18n="pricing.billing.monthly" type="button">Mensuel</button>
              <button class="pricing-billing-toggle__btn" data-billing="annual" data-i18n="pricing.billing.annual" type="button">Annuel (-20%)</button>
            </div>
            <div class="pricing-billing-note" id="pricing-billing-note">
              Prix affiches par mois. Facturation annuelle disponible avec 7 % de reduction.
            </div>
          </div>

          <!-- ── Panel Commerciaux ── -->
          <div class="pricing-panel pricing-panel--active" id="pricing-panel-mobile">
            <div class="pricing-grid pricing-grid--3col" style="margin-top:32px; max-width:1000px">

              <!-- Gratuit -->
              <article class="pricing-card pricing-card--muted reveal reveal-delay-1">
                <div class="pricing-plan" data-i18n="pricing.free.plan">Gratuit</div>
                <div class="pricing-price">
                  <span class="pricing-amount" style="font-size:2.8rem">0</span>
                  <span class="pricing-per" data-i18n="pricing.free.per">€ / mois</span>
                </div>
                <div class="pricing-card__limit">
                  <svg fill="none" viewBox="0 0 16 16" stroke-width="1.8" style="width:12px;height:12px;stroke:var(--muted)"><path stroke-linecap="round" stroke-linejoin="round" d="M8 1v9M5 7l3 3 3-3"/><path stroke-linecap="round" d="M2 13h12"/></svg>
                  <span data-i18n="pricing.free.limit">20 Crédits IA / mois</span>
                </div>
                <div class="pricing-divider"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat1">20 Crédits IA / mois</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat2">15 minutes d'enregistrement par rendez-vous</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat3">1 génération de rapport par jour</span></div>
                </div>
                <a
                  class="btn btn--ghost btn--md"
                  href="#final-cta"
                  style="width:100%;justify-content:center"
                  data-i18n="pricing.free.cta"
                  data-track-id="pricing_free"
                  data-track-type="download"
                  data-track-section="pricing"
                >Commencer gratuitement</a>
              </article>

              <!-- Pro -->
              <article class="pricing-card pricing-card--featured reveal reveal-delay-2">
                <div class="pricing-badge" data-i18n="pricing.pro.badge">Recommandé</div>
                <div class="pricing-plan" data-i18n="pricing.pro.plan">Pro</div>
                <div class="pricing-price">
                  <span class="pricing-currency">€</span>
                  <span class="pricing-amount js-billing-price" data-base-price="29">29</span>
                  <span class="pricing-per" data-i18n="pricing.pro.per">/ mois</span>
                </div>
                <div class="pricing-trial-badge">
                  <svg fill="none" viewBox="0 0 14 14" stroke-width="1.8" style="width:11px;height:11px;stroke:var(--green)"><circle cx="7" cy="7" r="5.5"/><path stroke-linecap="round" d="M7 4.5v2.5l1.5 1.5"/></svg>
                  <span data-i18n="pricing.pro.trial">Essai 7 jours gratuit</span>
                </div>
                <div class="pricing-divider" style="margin-top:18px"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat1">120 Crédits IA / mois</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat2">1 heure d'enregistrement par rendez-vous</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat3">4 génération de rapports par jour</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat4">1 génération de synthèse par semaine (7 jours d'historique, consomme des Crédits IA)</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat5">Statistiques journalières</span></div>
                </div>
                <a
                  class="btn btn--primary btn--md"
                  href="#final-cta"
                  style="width:100%;justify-content:center"
                  data-i18n="pricing.pro.cta"
                  data-track-id="pricing_pro"
                  data-track-type="download"
                  data-track-section="pricing"
                >Commencer →</a>
              </article>

              <!-- Business -->
              <article class="pricing-card reveal reveal-delay-3">
                <div class="pricing-plan" data-i18n="pricing.business.plan">Business</div>
                <div class="pricing-price">
                  <span class="pricing-currency">€</span>
                  <span class="pricing-amount js-billing-price" data-base-price="69">69</span>
                  <span class="pricing-per" data-i18n="pricing.business.per">/ mois</span>
                </div>
                <div class="pricing-trial-badge">
                  <svg fill="none" viewBox="0 0 14 14" stroke-width="1.8" style="width:11px;height:11px;stroke:var(--green)"><circle cx="7" cy="7" r="5.5"/><path stroke-linecap="round" d="M7 4.5v2.5l1.5 1.5"/></svg>
                  <span data-i18n="pricing.business.trial">Essai 7 jours gratuit</span>
                </div>
                <div class="pricing-divider" style="margin-top:18px"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat1">450 Crédits IA / mois</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat2">Enregistrement illimité par rendez-vous</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat3">Génération de rapports illimités par jour</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat4">Génération de synthèse illimités par jour (Jusqu'à 90 jours d'historique)</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat5">Statistiques journalières</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat6">Support prioritaire sous 8h</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat7">Accès anticipé aux nouvelles fonctionnalités</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat8">Max — assistant IA pour répondre à toutes vos questions</span></div>
                </div>
                <a
                  class="btn btn--ghost btn--md"
                  href="#final-cta"
                  style="width:100%;justify-content:center"
                  data-i18n="pricing.business.cta"
                  data-track-id="pricing_business"
                  data-track-type="download"
                  data-track-section="pricing"
                >Commencer →</a>
              </article>
            </div>
            <p class="pricing-note" style="margin-top:16px" data-i18n="pricing.mobile.note">Plans disponibles en abonnement mensuel. Les actions consomment des Crédits IA. Annulation à tout moment.</p>
          </div>

          <!-- ── Panel Managers ── -->
          <div class="pricing-panel pricing-panel--managers" id="pricing-panel-managers">
            <div class="pricing-grid" style="margin-top:32px">
            <!-- Plan Équipe -->
            <article class="pricing-card pricing-card--featured reveal reveal-delay-1">
              <div class="pricing-badge" data-i18n="pricing.team.badge">Recommandé</div>
              <div class="pricing-plan" data-i18n="pricing.team.plan">Équipe</div>
              <div class="pricing-price">
                <span class="pricing-currency">€</span>
                <span class="pricing-amount js-billing-price" data-base-price="49">49</span>
                <span class="pricing-per" data-i18n="pricing.team.per"
                  >par commercial par mois</span
                >
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.team.seats">De 5 à 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat2"
                    >Application mobile iOS & Android - tous les commerciaux</span
                  >
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat1"
                    >Plan Business inclus</span
                  >
                </div>

                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat3">Hub web de pilotage manager</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat4">Analyse des rapports des commerciaux par IA</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat5">Administration des points à remonter sur les rapports</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat6">Support email sous 24h</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat7">Max — assistant IA pour répondre à toutes vos questions</span>
                </div>
              </div>
              <a
                class="btn btn--primary btn--md"
                href="https://hub.reedly.ai"
                style="width: 100%; justify-content: center"
                data-i18n="pricing.team.cta"
                data-track-id="pricing_team"
                data-track-type="hub"
                data-track-section="pricing"
              >
                Commencer →
              </a>
            </article>

            <!-- Plan Entreprise -->
            <article class="pricing-card reveal reveal-delay-2">
              <div class="pricing-plan" data-i18n="pricing.enterprise.plan">Entreprise</div>
              <div class="pricing-price">
                <span class="pricing-contact" data-i18n="pricing.enterprise.price">Sur devis</span>
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.enterprise.seats">Plus de 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat1">Tout le plan Équipe inclus</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat2">Utilisateurs illimités</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat3"
                    >Templates sectoriels personnalisés</span
                  >
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat4">Intégration CRM sur demande</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat6">Formation et onboarding équipe</span>
                </div>
              </div>
              <a
                class="btn btn--ghost btn--md"
                href="#contact"
                style="width: 100%; justify-content: center"
                data-i18n="pricing.enterprise.cta"
                data-track-id="pricing_enterprise"
                data-track-type="contact"
                data-track-section="pricing"
              >
                Nous contacter →
              </a>
              <div class="pricing-note" data-i18n="pricing.enterprise.note">
                Réponse sous 24h ouvrées
              </div>
            </article>
          </div>
          <p class="pricing-note pricing-note-managers" style="margin-top:16px" data-i18n="pricing.managers.note">Aucun essai gratuit sur les plans managers. Déployez Reedly pour votre équipe en moins de 10 minutes.</p>
          </div><!-- end panel managers -->

        </div>
      </section>
