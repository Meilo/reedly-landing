---
// Pricing section, team-seat framing (block 7), 2 plans: Équipe / Grandes équipes.
// Monthly/annual billing toggle is wired to the shared JS in public/main.js
// (#pricing-billing-toggle + .js-billing-price[data-base-price] -> -14% annual).
// CTA is always "Réserver une démo" / "Nous contacter", never a self-serve subscribe.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const bookHref = `/${lang}#rdv`;

// Reused check icon markup.
const check = `<svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg>`;

const teamFeatures = [
  'pricing.team.feat1', 'pricing.team.feat2', 'pricing.team.feat3',
  'pricing.team.feat4', 'pricing.team.feat5', 'pricing.team.feat6',
  'pricing.team.feat7', 'pricing.team.feat8', 'pricing.team.feat9',
  'pricing.team.feat10',
];
const teamFeaturesFallback = [
  'Application iOS et Android',
  'Comptes rendus IA illimités',
  'Synthèses stratégiques périodiques',
  'Hub manager · vision 360° de l’équipe',
  'Identification des interlocuteurs',
  'Fiches clients auto-enrichies',
  'Analyse IA transversale de l’équipe',
  'Connecteurs CRM connus',
  'Assistant IA (Max)',
  'Support prioritaire',
];
const largeFeatures = [
  'pricing.large.feat1', 'pricing.large.feat2', 'pricing.large.feat3',
  'pricing.large.feat4', 'pricing.large.feat5',
];
const largeFeaturesFallback = [
  'Tout le plan Équipe',
  'Vocabulaire métier sur mesure',
  'Multi-équipes / multi-secteurs',
  'Account manager dédié',
  'Formation & onboarding sur site',
];
---

<!-- ── Pricing ── -->
<section class="section" id="pricing">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
      <h2 data-i18n-html="pricing.title">
        Un prix par commercial.<br /><em>Zéro surprise.</em>
      </h2>
      <p class="section__lead" data-i18n="pricing.lead">
        Facturé à l'organisation, à la taille réelle de votre équipe terrain.
      </p>

      <!-- Monthly / annual billing toggle (wired to shared JS) -->
      <div class="pricing-billing-toggle" id="pricing-billing-toggle" role="tablist" aria-label="Facturation">
        <button
          type="button"
          class="pricing-billing-toggle__btn pricing-billing-toggle__btn--active"
          data-billing="monthly"
          data-i18n="pricing.billing.monthly"
          data-track-id="pricing_billing_monthly"
          data-track-type="toggle"
          data-track-section="pricing">Mensuel</button>
        <button
          type="button"
          class="pricing-billing-toggle__btn"
          data-billing="annual"
          data-i18n="pricing.billing.annual"
          data-track-id="pricing_billing_annual"
          data-track-type="toggle"
          data-track-section="pricing">Annuel (-14%)</button>
      </div>
    </div>

    <!-- ── 2-card grid (team seats) ── -->
    <div class="pricing-cards pricing-cards--duo reveal">
      <!-- ── Équipe (featured) ── -->
      <article class="pricing-card pricing-card--v2 pricing-card--featured">
        <div class="pricing-badge" data-i18n="pricing.team.badge">Le plus choisi</div>
        <header class="pricing-card__head">
          <div>
            <div class="pricing-card__name" data-i18n="pricing.team.plan">Équipe</div>
            <div class="pricing-card__subtitle" data-i18n="pricing.team.subtitle">
              À partir de 3 commerciaux
            </div>
          </div>
          <div class="pricing-card__price-block">
            <div class="pricing-card__price">
              <span class="pricing-amount js-billing-price" data-base-price="49">49</span><span class="pricing-currency-inline">€</span>
            </div>
            <div class="pricing-card__per" data-i18n="pricing.team.per">
              / commercial / mois
            </div>
          </div>
        </header>

        <div class="pricing-card__divider"></div>

        <ul class="pricing-features">
          {teamFeatures.map((key, i) => (
            <li class="pricing-feature">
              <span class="pricing-feature__check" set:html={check}></span>
              <span data-i18n={key}>{teamFeaturesFallback[i]}</span>
            </li>
          ))}
        </ul>

        <a
          class="btn btn--primary btn--md pricing-card__cta"
          href={bookHref}
          data-link-fr="/fr#rdv"
          data-link-en="/en#rdv"
          data-i18n="pricing.book_demo"
          data-track-id="pricing_team_book_demo"
          data-track-type="demo"
          data-track-section="pricing">
          Réserver une démo →
        </a>
      </article>

      <!-- ── Grandes équipes ── -->
      <article class="pricing-card pricing-card--v2">
        <header class="pricing-card__head">
          <div>
            <div class="pricing-card__name" data-i18n="pricing.large.plan">Entreprise</div>
            <div class="pricing-card__subtitle" data-i18n="pricing.large.subtitle">
              16+ commerciaux
            </div>
          </div>
          <div class="pricing-card__price-block">
            <div class="pricing-card__price pricing-card__price--text">
              <span data-i18n="pricing.large.price">Sur devis</span>
            </div>
            <div class="pricing-card__per">&nbsp;</div>
          </div>
        </header>

        <div class="pricing-card__divider"></div>

        <ul class="pricing-features">
          {largeFeatures.map((key, i) => (
            <li class="pricing-feature">
              <span class="pricing-feature__check" set:html={check}></span>
              <span data-i18n={key}>{largeFeaturesFallback[i]}</span>
            </li>
          ))}
        </ul>

        <a
          class="btn btn--ghost btn--md pricing-card__cta"
          href={bookHref}
          data-link-fr="/fr#rdv"
          data-link-en="/en#rdv"
          data-i18n="pricing.contact_us"
          data-track-id="pricing_large_contact"
          data-track-type="demo"
          data-track-section="pricing">
          Nous contacter →
        </a>
      </article>
    </div>

    <p class="pricing-billing-note" id="pricing-billing-note" style="margin-top:20px;text-align:center" data-i18n="pricing.billing.note.monthly">
      Prix affichés par mois. Facturation annuelle disponible avec 14 % de réduction.
    </p>

    <p class="pricing-note" style="margin-top:8px" data-i18n="pricing.note">
      Sans engagement · résiliable à tout moment
    </p>
  </div>
</section>

<style>
  .pricing-cards--duo {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
    align-items: stretch;
  }
  .pricing-cards--duo .pricing-card {
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .pricing-cards--duo .pricing-card__cta {
    margin-top: auto;
  }
  #pricing-billing-toggle {
    display: flex;
    width: fit-content;
    margin: 22px auto 0;
  }
  @media (max-width: 720px) {
    .pricing-cards--duo {
      grid-template-columns: 1fr;
    }
  }
</style>
