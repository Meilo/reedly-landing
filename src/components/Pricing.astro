---
// Pricing section — 3-card layout (Pro / Business / Enterprise)
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const trialHref = 'https://hub.reedly.ai';
const contactHref = `/${lang}#contact`;
---

<!-- ── Pricing ── -->
<section class="section" id="pricing">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
      <h2 data-i18n-html="pricing.title">
        Équipez votre force de vente<br /><em>avec l'IA terrain.</em>
      </h2>
      <p class="section__lead" data-i18n="pricing.lead">
        Rapports structurés illimités, vocabulaire métier, Hub manager. Déployez Reedly en moins de
        10 minutes.
      </p>
    </div>

    <!-- Billing toggle -->
    <div class="pricing-toggle-wrap reveal">
      <div class="pricing-billing-toggle" id="pricing-billing-toggle">
        <button
          class="pricing-billing-toggle__btn pricing-billing-toggle__btn--active"
          data-billing="monthly"
          data-i18n="pricing.billing.monthly"
          type="button">Mensuel</button>
        <button
          class="pricing-billing-toggle__btn"
          data-billing="annual"
          data-i18n="pricing.billing.annual"
          type="button">Annuel (-20%)</button>
      </div>
    </div>

    <!-- ── 3-card grid ── -->
    <div class="pricing-cards reveal">
      <!-- ── Pro Team ── -->
      <article class="pricing-card pricing-card--v2">
        <header class="pricing-card__head">
          <div>
            <div class="pricing-card__name" data-i18n="pricing.pro.plan">Pro</div>
            <div class="pricing-card__subtitle" data-i18n="pricing.pro.subtitle">
              Équipe découverte
            </div>
          </div>
          <div class="pricing-card__price-block">
            <div class="pricing-card__price">
              <span class="pricing-amount js-billing-price" data-base-price="29">29</span><span
                class="pricing-currency-inline">€</span>
            </div>
            <div class="pricing-card__per" data-i18n="pricing.tableHeader.per">
              / utilisateur / mois
            </div>
          </div>
        </header>

        <div class="pricing-card__divider"></div>

        <div class="pricing-card__section-label" data-i18n="pricing.cap.title">Capacités</div>
        <div class="pricing-capacities">
          <div class="pricing-capacity" style="--fill:35%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.recording"
                >Durée par enregistrement</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.recording.pro"
                >45 min</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.reports"
                >Rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.tableVal.unlimited">Illimité</span>
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:35%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.history"
                >Historique des rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.history.pro"
                >30 jours</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:30%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.support">Support</span>
              <span class="pricing-capacity__value" data-i18n="pricing.cap.support.pro">Email</span>
            </div>
          </div>
        </div>

        <div class="pricing-card__section-label" data-i18n="pricing.included.title">Inclus</div>
        <ul class="pricing-features">
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.pro.feat1">Rapports structurés · synthèses · Max IA</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.pro.feat2">Hub web · visibilité équipe</span>
          </li>
          <li class="pricing-feature pricing-feature--missing">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg
            ></span>
            <span data-i18n="pricing.pro.feat3">Distinction vocale</span>
          </li>
          <li class="pricing-feature pricing-feature--missing">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg
            ></span>
            <span data-i18n="pricing.pro.feat4">Intégration CRM</span>
          </li>
          <li class="pricing-feature pricing-feature--missing">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg
            ></span>
            <span data-i18n="pricing.pro.feat5">Analyse croisée équipe</span>
          </li>
        </ul>

        <a
          class="btn btn--ghost btn--md pricing-card__cta"
          href={trialHref}
          data-i18n="pricing.ctaGetStarted"
          data-track-id="pricing_pro"
          data-track-type="trial"
          data-track-section="pricing">
          Démarrer gratuitement →
        </a>
      </article>

      <!-- ── Équipe (featured) ── -->
      <article class="pricing-card pricing-card--v2 pricing-card--featured">
        <div class="pricing-badge" data-i18n="pricing.team.badge">Recommandé</div>
        <header class="pricing-card__head">
          <div>
            <div class="pricing-card__name" data-i18n="pricing.team.plan">Business</div>
            <div class="pricing-card__subtitle" data-i18n="pricing.team.subtitle">
              Force de vente structurée
            </div>
          </div>
          <div class="pricing-card__price-block">
            <div class="pricing-card__price">
              <span class="pricing-amount js-billing-price" data-base-price="69">69</span><span
                class="pricing-currency-inline">€</span>
            </div>
            <div class="pricing-card__per" data-i18n="pricing.tableHeader.per">
              / utilisateur / mois
            </div>
          </div>
        </header>

        <div class="pricing-card__divider"></div>

        <div class="pricing-card__section-label" data-i18n="pricing.cap.title">Capacités</div>
        <div class="pricing-capacities">
          <div class="pricing-capacity" style="--fill:55%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.recording"
                >Durée par enregistrement</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.recording.team">1 h</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.reports"
                >Rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.tableVal.unlimited">Illimité</span>
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:90%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.history"
                >Historique des rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.history.team"
                >90 jours</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:75%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.support">Support</span>
              <span class="pricing-capacity__value" data-i18n="pricing.cap.support.team"
                >Prioritaire 24h</span
              >
            </div>
          </div>
        </div>

        <div class="pricing-card__section-label" data-i18n="pricing.included.title">Inclus</div>
        <ul class="pricing-features">
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.team.feat1">Tout Pro</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.team.feat2">Distinction vocale (qui parle quand)</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.team.feat3">Intégration CRM (HubSpot, Salesforce…)</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.team.feat4">Analyse IA croisée de l'équipe entière</span>
          </li>
          <li class="pricing-feature pricing-feature--missing">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg
            ></span>
            <span data-i18n="pricing.team.feat5">Vocabulaire métier custom</span>
          </li>
        </ul>

        <a
          class="btn btn--primary btn--md pricing-card__cta"
          href={trialHref}
          data-i18n="pricing.ctaGetStarted"
          data-track-id="pricing_team"
          data-track-type="trial"
          data-track-section="pricing">
          Démarrer gratuitement →
        </a>
      </article>

      <!-- ── Entreprise ── -->
      <article class="pricing-card pricing-card--v2">
        <header class="pricing-card__head">
          <div>
            <div class="pricing-card__name" data-i18n="pricing.enterprise.plan">Entreprise</div>
            <div class="pricing-card__subtitle" data-i18n="pricing.enterprise.subtitle">
              Multi-secteurs · sur mesure
            </div>
          </div>
          <div class="pricing-card__price-block">
            <div class="pricing-card__price pricing-card__price--text">
              <span data-i18n="pricing.enterprise.price">Sur devis</span>
            </div>
            <div class="pricing-card__per">&nbsp;</div>
          </div>
        </header>

        <div class="pricing-card__divider"></div>

        <div class="pricing-card__section-label" data-i18n="pricing.cap.title">Capacités</div>
        <div class="pricing-capacities">
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.recording"
                >Durée par enregistrement</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.recording.enterprise"
                >2 h</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.reports"
                >Rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.tableVal.custom"
                >Sur mesure</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.history"
                >Historique des rapports</span
              >
              <span class="pricing-capacity__value" data-i18n="pricing.cap.history.enterprise"
                >Illimité</span
              >
            </div>
          </div>
          <div class="pricing-capacity" style="--fill:100%">
            <div class="pricing-capacity__row">
              <span class="pricing-capacity__label" data-i18n="pricing.cap.support">Support</span>
              <span class="pricing-capacity__value" data-i18n="pricing.cap.support.enterprise"
                >Account manager</span
              >
            </div>
          </div>
        </div>

        <div class="pricing-card__section-label" data-i18n="pricing.custom.title">Sur-mesure</div>
        <ul class="pricing-features">
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.enterprise.feat1">Tout Business</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.enterprise.feat2">Vocabulaire métier personnalisé</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.enterprise.feat3">Multi-équipes / multi-secteurs</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.enterprise.feat4">Account manager dédié</span>
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature__check"
              ><svg fill="none" viewBox="0 0 12 12" stroke-width="2"
                ><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg
            ></span>
            <span data-i18n="pricing.enterprise.feat5">Formation & onboarding sur site</span>
          </li>
        </ul>

        <a
          class="btn btn--ghost btn--md pricing-card__cta"
          href={contactHref}
          data-i18n="pricing.enterprise.cta"
          data-track-id="pricing_enterprise"
          data-track-type="contact"
          data-track-section="pricing">
          Nous contacter →
        </a>
      </article>
    </div>

    <p class="pricing-note" style="margin-top:24px" data-i18n="pricing.managers.note">
      Déployez Reedly pour votre équipe en moins de 10 minutes. Annulation à tout moment.
    </p>
  </div>
</section>
