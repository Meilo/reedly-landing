---
// Pricing section — enterprise-focused (solo plans available in mobile app only)
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const trialHref = 'https://hub.reedly.ai';
const contactHref = `/${lang}#contact`;
---

<!-- ── Pricing ── -->
      <section class="section" id="pricing">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
            <h2 data-i18n-html="pricing.title">
              Équipez votre force de vente<br /><em>avec l'IA terrain.</em>
            </h2>
            <p class="section__lead" data-i18n="pricing.lead">
              Les autres transcrivent les réunions. Reedly les comprend. — 3x moins cher que Modjo, 10x moins cher que Gong.
            </p>
          </div>

          <!-- Billing toggle -->
          <div class="pricing-toggle-wrap reveal">
            <div class="pricing-billing-toggle" id="pricing-billing-toggle">
              <button class="pricing-billing-toggle__btn pricing-billing-toggle__btn--active" data-billing="monthly" data-i18n="pricing.billing.monthly" type="button">Mensuel</button>
              <button class="pricing-billing-toggle__btn" data-billing="annual" data-i18n="pricing.billing.annual" type="button">Annuel (-15%)</button>
            </div>
          </div>

          <!-- ── Plans ── -->
          <div class="pricing-panel pricing-panel--active" id="pricing-panel-managers">
            <div class="pricing-grid" style="margin-top:32px">
            <!-- Plan Équipe -->
            <article class="pricing-card pricing-card--featured reveal reveal-delay-1">
              <div class="pricing-badge" data-i18n="pricing.team.badge">Recommandé</div>
              <div class="pricing-plan" data-i18n="pricing.team.plan">Équipe</div>
              <div class="pricing-price">
                <span class="pricing-currency">€</span>
                <span class="pricing-amount js-billing-price" data-base-price="69">69</span>
                <span class="pricing-per" data-i18n="pricing.team.per"
                  >par utilisateur par mois</span
                >
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.team.seats">De 5 à 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <!-- Per-rep features -->
                <div class="pricing-feature-group-label" data-i18n="pricing.team.groupRep">Pour chaque commercial</div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featApp">Application mobile iOS & Android</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featReports">Rapports structurés illimités</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featRecording">Jusqu'à 2h d'enregistrement par rendez-vous</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featSyntheses">Synthèses stratégiques</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featDiarization">Distinction vocale</span>
                </div>

                <!-- Manager features -->
                <div class="pricing-feature-group-label" style="margin-top:12px" data-i18n="pricing.team.groupManager">Pour le manager</div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featHub">Rapports, synthèses et stats de toute l'équipe</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featAnalysis">Analyse IA des rapports de toute l'équipe</span>
                </div>

                <!-- Shared features -->
                <div class="pricing-feature-group-label" style="margin-top:12px" data-i18n="pricing.team.groupShared">Pour tous</div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featCreditsShared">450 crédits IA / mois par utilisateur</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featMaxAll">Max — assistant IA (mobile + hub web)</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.team.featSupport">Support prioritaire sous 24h</span>
                </div>
              </div>
              <a
                class="btn btn--primary btn--md"
                href={trialHref}
                style="width: 100%; justify-content: center"
                data-i18n="pricing.team.cta"
                data-track-id="pricing_team"
                data-track-type="trial"
                data-track-section="pricing"
              >
                Essayer gratuitement →
              </a>
            </article>

            <!-- Plan Entreprise -->
            <article class="pricing-card reveal reveal-delay-2">
              <div class="pricing-plan" data-i18n="pricing.enterprise.plan">Entreprise</div>
              <div class="pricing-price">
                <span class="pricing-contact" data-i18n="pricing.enterprise.price">Sur devis</span>
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.enterprise.seats">Plus de 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.feat1">Tout le plan Équipe inclus</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.feat2">Utilisateurs illimités</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.featMultiTeam">Multi-équipes / multi-secteurs</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.featCredits">Volume de crédits IA sur mesure</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.featAccountManager">Account manager dédié</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.feat3">Vocabulaire et process de votre entreprise intégrés à l'IA</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.feat4">Intégration CRM sur demande</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></div>
                  <span data-i18n="pricing.enterprise.feat6">Formation et onboarding équipe</span>
                </div>
              </div>
              <a
                class="btn btn--ghost btn--md"
                href={contactHref}
                data-link-fr="/fr#contact"
                data-link-en="/en#contact"
                style="width: 100%; justify-content: center"
                data-i18n="pricing.enterprise.cta"
                data-track-id="pricing_enterprise"
                data-track-type="contact"
                data-track-section="pricing"
              >
                Nous contacter →
              </a>
              <div class="pricing-note" data-i18n="pricing.enterprise.note">
                Réponse sous 24h ouvrées
              </div>
            </article>
          </div>
          <p class="pricing-note" style="margin-top:16px" data-i18n="pricing.managers.note">Déployez Reedly pour votre équipe en moins de 10 minutes. Annulation à tout moment.</p>
          </div><!-- end plans -->

        </div>
      </section>
