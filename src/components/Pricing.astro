---
// Pricing section — enterprise-focused (solo plans available in mobile app only)
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
const trialHref = 'https://hub.reedly.ai';
const contactHref = `/${lang}#contact`;
---

<!-- ── Pricing ── -->
      <section class="section" id="pricing">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
            <h2 data-i18n-html="pricing.title">
              Équipez votre force de vente<br /><em>avec l'IA terrain.</em>
            </h2>
            <p class="section__lead" data-i18n="pricing.lead">
              Les autres transcrivent les réunions. Reedly les comprend. — 3x moins cher que Modjo, 10x moins cher que Gong.
            </p>
          </div>

          <!-- Billing toggle -->
          <div class="pricing-toggle-wrap reveal">
            <div class="pricing-billing-toggle" id="pricing-billing-toggle">
              <button class="pricing-billing-toggle__btn pricing-billing-toggle__btn--active" data-billing="monthly" data-i18n="pricing.billing.monthly" type="button">Mensuel</button>
              <button class="pricing-billing-toggle__btn" data-billing="annual" data-i18n="pricing.billing.annual" type="button">Annuel (-15%)</button>
            </div>
          </div>

          <!-- ── Comparison table ── -->
          <div class="pricing-panel pricing-panel--active" id="pricing-panel-managers">
            <div class="pricing-table-wrap reveal" style="margin-top:32px">
            <table class="pricing-table">
              <colgroup>
                <col class="pricing-table__col-feature" />
                <col class="pricing-table__col-plan" />
                <col class="pricing-table__col-plan pricing-table__col-plan--featured" />
                <col class="pricing-table__col-plan" />
              </colgroup>
              <thead>
                <tr>
                  <th></th>
                  <th>
                    <div class="pricing-table__plan-name" data-i18n="pricing.pro.plan">Pro Team</div>
                    <div class="pricing-table__plan-price">
                      <span class="pricing-currency">€</span>
                      <span class="pricing-amount js-billing-price" data-base-price="29">29</span>
                    </div>
                    <div class="pricing-table__plan-per" data-i18n="pricing.tableHeader.per">/ utilisateur / mois</div>
                  </th>
                  <th class="pricing-table__head-cell--featured">
                    <div class="pricing-table__featured-badge" data-i18n="pricing.team.badge">Recommandé</div>
                    <div class="pricing-table__plan-name" data-i18n="pricing.team.plan">Équipe</div>
                    <div class="pricing-table__plan-price">
                      <span class="pricing-currency">€</span>
                      <span class="pricing-amount js-billing-price" data-base-price="69">69</span>
                    </div>
                    <div class="pricing-table__plan-per" data-i18n="pricing.tableHeader.per">/ utilisateur / mois</div>
                  </th>
                  <th>
                    <div class="pricing-table__plan-name" data-i18n="pricing.enterprise.plan">Entreprise</div>
                    <div class="pricing-table__plan-price pricing-table__plan-price--text" data-i18n="pricing.enterprise.price">Sur devis</div>
                    <div class="pricing-table__plan-per">&nbsp;</div>
                  </th>
                </tr>
              </thead>
              <tbody>
                <!-- Capture & rapports -->
                <tr class="pricing-table__category">
                  <td colspan="4" data-i18n="pricing.tableCat.capture">Capture & rapports</td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.app">Application mobile iOS & Android</td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.recording">Enregistrement max par rendez-vous</td>
                  <td>45 min</td>
                  <td>2 h</td>
                  <td>2 h</td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.reports">Rapports structurés après chaque rendez-vous</td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.syntheses">Synthèses stratégiques sur plusieurs rapports</td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.history">Historique des rapports</td>
                  <td><span data-i18n="pricing.tableVal.history.pro">30 jours</span></td>
                  <td><span data-i18n="pricing.tableVal.history.team">90 jours</span></td>
                  <td><span data-i18n="pricing.tableVal.unlimited">Illimité</span></td>
                </tr>

                <!-- Intelligence IA -->
                <tr class="pricing-table__category">
                  <td colspan="4" data-i18n="pricing.tableCat.ai">Intelligence IA</td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.max">Max — assistant IA</td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.credits">Crédits IA / mois / utilisateur</td>
                  <td>80</td>
                  <td>450</td>
                  <td><span data-i18n="pricing.tableVal.custom">Sur mesure</span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.diarization">Distinction vocale (qui parle quand)</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.crossTeamAi">Analyse IA croisée de toute l'équipe</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>

                <!-- Pilotage & intégrations -->
                <tr class="pricing-table__category">
                  <td colspan="4" data-i18n="pricing.tableCat.hub">Pilotage & intégrations</td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.hub">Hub web — visibilité équipe complète</td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.crm">Intégration CRM (Axonaut, HubSpot…)</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>

                <!-- Personnalisation & service -->
                <tr class="pricing-table__category">
                  <td colspan="4" data-i18n="pricing.tableCat.custom">Personnalisation & service</td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.vocab">Vocabulaire métier custom</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.multiTeam">Multi-équipes / multi-secteurs</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.accountManager">Account manager dédié</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.training">Formation et onboarding équipe</td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__cross" aria-label="non"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3l6 6M9 3l-6 6" /></svg></span></td>
                  <td><span class="pricing-table__check" aria-label="oui"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" /></svg></span></td>
                </tr>
                <tr>
                  <td data-i18n="pricing.tableRow.support">Support</td>
                  <td><span data-i18n="pricing.tableVal.support.pro">Email</span></td>
                  <td><span data-i18n="pricing.tableVal.support.team">Prioritaire 24h</span></td>
                  <td><span data-i18n="pricing.tableVal.support.enterprise">Account manager</span></td>
                </tr>
              </tbody>
              <tfoot>
                <tr>
                  <td></td>
                  <td>
                    <a class="btn btn--ghost btn--md pricing-table__cta"
                       href={trialHref}
                       data-i18n="pricing.ctaGetStarted"
                       data-track-id="pricing_pro"
                       data-track-type="trial"
                       data-track-section="pricing">
                      Démarrer gratuitement →
                    </a>
                  </td>
                  <td>
                    <a class="btn btn--primary btn--md pricing-table__cta"
                       href={trialHref}
                       data-i18n="pricing.ctaGetStarted"
                       data-track-id="pricing_team"
                       data-track-type="trial"
                       data-track-section="pricing">
                      Démarrer gratuitement →
                    </a>
                  </td>
                  <td>
                    <a class="btn btn--ghost btn--md pricing-table__cta"
                       href={trialHref}
                       data-i18n="pricing.ctaGetStarted"
                       data-track-id="pricing_enterprise"
                       data-track-type="trial"
                       data-track-section="pricing">
                      Démarrer gratuitement →
                    </a>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
          <p class="pricing-note" style="margin-top:16px" data-i18n="pricing.managers.note">Déployez Reedly pour votre équipe en moins de 10 minutes. Annulation à tout moment.</p>
          </div><!-- end plans -->

        </div>
      </section>
