---
// Pricing section
---

<!-- ── Pricing ── -->
      <section class="section" id="pricing">
        <div class="inner">
          <div class="reveal">
            <div class="section__eyebrow" data-i18n="pricing.eyebrow">Tarifs</div>
            <h2 data-i18n-html="pricing.title">
              Un tarif pour chaque<br /><em>profil terrain.</em>
            </h2>
            <p class="section__lead" data-i18n="pricing.lead">
              Que vous soyez commercial indépendant ou responsable d'une équipe, Reedly a un plan pour vous.
            </p>
          </div>

          <!-- Toggle -->
          <div class="pricing-toggle-wrap reveal">
            <div class="pricing-toggle" id="pricing-toggle">
              <button class="pricing-toggle__btn pricing-toggle__btn--active" data-panel="mobile" data-i18n="pricing.toggle.mobile" type="button">Commerciaux</button>
              <button class="pricing-toggle__btn" data-panel="managers" data-i18n="pricing.toggle.managers" type="button">Managers / Équipes</button>
            </div>
          </div>

          <!-- ── Panel Commerciaux ── -->
          <div class="pricing-panel pricing-panel--active" id="pricing-panel-mobile">
            <div class="pricing-grid pricing-grid--3col" style="margin-top:32px; max-width:1000px">

              <!-- Gratuit -->
              <article class="pricing-card pricing-card--muted reveal reveal-delay-1">
                <div class="pricing-plan" data-i18n="pricing.free.plan">Gratuit</div>
                <div class="pricing-price">
                  <span class="pricing-amount" style="font-size:2.8rem">0</span>
                  <span class="pricing-per" data-i18n="pricing.free.per">€ / mois</span>
                </div>
                <div class="pricing-card__limit">
                  <svg fill="none" viewBox="0 0 16 16" stroke-width="1.8" style="width:12px;height:12px;stroke:var(--muted)"><path stroke-linecap="round" stroke-linejoin="round" d="M8 1v9M5 7l3 3 3-3"/><path stroke-linecap="round" d="M2 13h12"/></svg>
                  <span data-i18n="pricing.free.limit">3 rapports / mois</span>
                </div>
                <div class="pricing-divider"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat1">Enregistrement live iOS &amp; Android</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat2">Rapport structuré (6 sections)</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat3">Export PDF des rapports</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.free.feat4">Stockage 30 jours</span></div>
                </div>
                <a class="btn btn--ghost btn--md" href="#final-cta" style="width:100%;justify-content:center" data-i18n="pricing.free.cta">Commencer gratuitement</a>
              </article>

              <!-- Pro -->
              <article class="pricing-card pricing-card--featured reveal reveal-delay-2">
                <div class="pricing-badge" data-i18n="pricing.pro.badge">Recommandé</div>
                <div class="pricing-plan" data-i18n="pricing.pro.plan">Pro</div>
                <div class="pricing-price">
                  <span class="pricing-currency">€</span>
                  <span class="pricing-amount">19</span>
                  <span class="pricing-per" data-i18n="pricing.pro.per">/ mois</span>
                </div>
                <div class="pricing-trial-badge">
                  <svg fill="none" viewBox="0 0 14 14" stroke-width="1.8" style="width:11px;height:11px;stroke:var(--green)"><circle cx="7" cy="7" r="5.5"/><path stroke-linecap="round" d="M7 4.5v2.5l1.5 1.5"/></svg>
                  <span data-i18n="pricing.pro.trial">Essai 7 jours gratuit</span>
                </div>
                <div class="pricing-divider" style="margin-top:18px"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat1">Rapports IA illimités</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat2">Rapport complet en 11 sections</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat3">Expert sectoriel intégré</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat4">3 synthèses par mois</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat5">Export PDF illimité</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.pro.feat6">Support email sous 24h</span></div>
                </div>
                <a class="btn btn--primary btn--md" href="#final-cta" style="width:100%;justify-content:center" data-i18n="pricing.pro.cta">Commencer →</a>
              </article>

              <!-- Business -->
              <article class="pricing-card reveal reveal-delay-3">
                <div class="pricing-plan" data-i18n="pricing.business.plan">Business</div>
                <div class="pricing-price">
                  <span class="pricing-currency">€</span>
                  <span class="pricing-amount">49</span>
                  <span class="pricing-per" data-i18n="pricing.business.per">/ mois</span>
                </div>
                <div class="pricing-trial-badge">
                  <svg fill="none" viewBox="0 0 14 14" stroke-width="1.8" style="width:11px;height:11px;stroke:var(--green)"><circle cx="7" cy="7" r="5.5"/><path stroke-linecap="round" d="M7 4.5v2.5l1.5 1.5"/></svg>
                  <span data-i18n="pricing.business.trial">Essai 7 jours gratuit</span>
                </div>
                <div class="pricing-divider" style="margin-top:18px"></div>
                <div class="pricing-features">
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat1">Tout le plan Pro inclus</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat2">Synthèses illimitées</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat3">Tous les secteurs disponibles</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat4">Historique illimité</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat5">Support prioritaire sous 8h</span></div>
                  <div class="pricing-feature"><div class="pricing-feature__check"><svg fill="none" viewBox="0 0 12 12" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5"/></svg></div><span data-i18n="pricing.business.feat6">Accès anticipé aux nouvelles fonctionnalités</span></div>
                </div>
                <a class="btn btn--ghost btn--md" href="#final-cta" style="width:100%;justify-content:center" data-i18n="pricing.business.cta">Commencer →</a>
              </article>
            </div>
            <p class="pricing-note" style="margin-top:16px" data-i18n="pricing.mobile.note">Plans disponibles en abonnement mensuel. Annulation à tout moment.</p>
          </div>

          <!-- ── Panel Managers ── -->
          <div class="pricing-panel pricing-panel--managers" id="pricing-panel-managers">
            <div class="pricing-grid" style="margin-top:32px">
            <!-- Plan Équipe -->
            <article class="pricing-card pricing-card--featured reveal reveal-delay-1">
              <div class="pricing-badge" data-i18n="pricing.team.badge">Recommandé</div>
              <div class="pricing-plan" data-i18n="pricing.team.plan">Équipe</div>
              <div class="pricing-price">
                <span class="pricing-currency">€</span>
                <span class="pricing-amount">39</span>
                <span class="pricing-per" data-i18n="pricing.team.per"
                  >par commercial par mois</span
                >
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.team.seats">De 5 à 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat1"
                    >App mobile iOS &amp; Android — tous les membres</span
                  >
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat2">Rapports IA illimités par utilisateur</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat3">Synthèses territoriales à la demande</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat4">Hub web de pilotage manager inclus</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat5">Export PDF des rapports</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.team.feat6">Support email sous 24h</span>
                </div>
              </div>
              <a
                class="btn btn--primary btn--md"
                href="#final-cta"
                style="width: 100%; justify-content: center"
                data-i18n="pricing.team.cta"
              >
                Commencer →
              </a>
            </article>

            <!-- Plan Entreprise -->
            <article class="pricing-card reveal reveal-delay-2">
              <div class="pricing-plan" data-i18n="pricing.enterprise.plan">Entreprise</div>
              <div class="pricing-price">
                <span class="pricing-contact" data-i18n="pricing.enterprise.price">Sur devis</span>
              </div>
              <div class="pricing-seats">
                <svg fill="none" viewBox="0 0 24 24" stroke-width="1.8">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                  />
                </svg>
                <span data-i18n="pricing.enterprise.seats">Plus de 20 commerciaux</span>
              </div>
              <div class="pricing-divider"></div>
              <div class="pricing-features">
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat1">Tout le plan Équipe inclus</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat2">Utilisateurs illimités</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat3"
                    >Templates sectoriels personnalisés</span
                  >
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat4">Intégration CRM sur demande</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat5">Account manager dédié</span>
                </div>
                <div class="pricing-feature">
                  <div class="pricing-feature__check">
                    <svg fill="none" viewBox="0 0 12 12" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2 6l3 3 5-5" />
                    </svg>
                  </div>
                  <span data-i18n="pricing.enterprise.feat6">Formation et onboarding équipe</span>
                </div>
              </div>
              <a
                class="btn btn--ghost btn--md"
                href="mailto:contact@reedly.ai"
                style="width: 100%; justify-content: center"
                data-i18n="pricing.enterprise.cta"
              >
                Nous contacter →
              </a>
              <div class="pricing-note" data-i18n="pricing.enterprise.note">
                Réponse sous 24h ouvrées
              </div>
            </article>
          </div>
          <p class="pricing-note pricing-note-managers" style="margin-top:16px" data-i18n="pricing.managers.note">Aucun essai gratuit sur les plans managers. Déployez Reedly pour votre équipe en moins de 10 minutes.</p>
          </div><!-- end panel managers -->

        </div>
      </section>
