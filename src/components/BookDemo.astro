---
// Book a demo (block 6), qualifying form + calendar embed placeholder.
// Front-only for now: no POST, the submit reveals a calendar placeholder to wire
// to Cal.com / Calendly later.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
---

<!-- ── Book a demo ── -->
<section class="section section--alt" id="rdv">
  <div class="inner">
    <div class="reveal">
      <div class="section__eyebrow" data-i18n="bookdemo.eyebrow">Réserver une démo</div>
      <h2 data-i18n-html="bookdemo.title">En 15 minutes, voyez<br /><em>ce que vos agences vous disent vraiment.</em></h2>
      <p class="section__lead" data-i18n="bookdemo.lead">
        Une démo cadrée sur vos destinations et vos agences.
      </p>
    </div>

    <div class="contact__grid">
      <!-- Left: value / reassurance -->
      <div class="bookdemo__intro reveal">
        <p class="bookdemo__text" data-i18n="bookdemo.intro">
          Vous repartez en sachant ce que ça change pour votre équipe, dès la première semaine.
        </p>
      </div>

      <!-- Right: qualifying form -->
      <div class="contact__form-card reveal">
        <form id="bookdemo-form" novalidate>
          <div class="form__field">
            <label class="form__label" for="bd-role" data-i18n="bookdemo.role.label"
              >Votre poste</label
            >
            <select class="form__select" id="bd-role" name="role" required>
              <option value="" disabled selected data-i18n="bookdemo.role.select"
                >Choisir…</option
              >
              <option value="head_of_sales" data-i18n="bookdemo.role.director"
                >Directeur / Responsable commercial</option
              >
              <option value="founder_ceo" data-i18n="bookdemo.role.owner">Dirigeant / Gérant</option>
              <option value="sales_rep" data-i18n="bookdemo.role.rep">Commercial terrain</option>
              <option value="other" data-i18n="bookdemo.role.other">Autre</option>
            </select>
          </div>

          <div class="form__field">
            <label class="form__label" for="bd-team" data-i18n="bookdemo.team.label"
              >Taille de l'équipe commerciale</label
            >
            <select class="form__select" id="bd-team" name="team_size" required>
              <option value="" disabled selected data-i18n="bookdemo.team.select"
                >Choisir…</option
              >
              <option value="1" data-i18n="bookdemo.team.1">1 commercial</option>
              <option value="2-5" data-i18n="bookdemo.team.2_5">2 à 5</option>
              <option value="6-15" data-i18n="bookdemo.team.6_15">6 à 15</option>
              <option value="16+" data-i18n="bookdemo.team.16">16+</option>
            </select>
          </div>

          <div class="form__field">
            <label class="form__label" for="bd-sector" data-i18n="bookdemo.sector.label"
              >Secteur</label
            >
            <select class="form__select" id="bd-sector" name="sector">
              <option value="" disabled selected data-i18n="bookdemo.sector.select"
                >Choisir…</option
              >
              <option value="tour_operateur" data-i18n="bookdemo.sector.to"
                >Tour-opérateur / Voyagiste</option
              >
              <option value="agence_voyages" data-i18n="bookdemo.sector.agency"
                >Agence de voyages</option
              >
              <option value="receptif_dmc" data-i18n="bookdemo.sector.dmc"
                >Réceptif / DMC</option
              >
              <option value="mice" data-i18n="bookdemo.sector.mice"
                >MICE &amp; événementiel</option
              >
              <option value="transport" data-i18n="bookdemo.sector.transport"
                >Transport &amp; mobilité</option
              >
              <option value="croisiere" data-i18n="bookdemo.sector.cruise">Croisière</option>
              <option value="hotellerie" data-i18n="bookdemo.sector.hospitality"
                >Hôtellerie &amp; hébergement</option
              >
              <option value="loisirs" data-i18n="bookdemo.sector.leisure"
                >Loisirs &amp; billetterie</option
              >
              <option value="other" data-i18n="bookdemo.sector.other">Autre secteur</option>
            </select>
          </div>

          <div class="form__field">
            <label class="form__label" for="bd-email" data-i18n="bookdemo.email.label"
              >Email professionnel</label
            >
            <input
              class="form__input"
              type="email"
              id="bd-email"
              name="email"
              placeholder="vous@votre-organisation.fr"
              data-i18n-placeholder="bookdemo.email.ph"
              required
              autocomplete="email"
            />
          </div>

          <button
            class="btn btn--primary form__submit"
            type="submit"
            id="bd-submit"
            data-i18n="bookdemo.submit"
            data-track-id="bookdemo_submit"
            data-track-type="demo"
            data-track-section="bookdemo"
          >
            Voir les créneaux disponibles →
          </button>

          <div class="bookdemo__hint" data-i18n="bookdemo.hint">
            Aucune carte bancaire · réponse sous 24h
          </div>
        </form>

        <!-- Calendar embed placeholder, revealed after the qualifying step.
             Wire to Cal.com / Calendly here later. -->
        <div class="bookdemo__calendar" id="bookdemo-calendar" hidden>
          <div class="bookdemo__calendar-box">
            <span data-i18n="bookdemo.calendar">[ Embed calendrier · Cal.com / Calendly à brancher ]</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bookdemo__intro {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .bookdemo__text {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 18px;
  }
  /* lift the global 22ch cap so "ce que vos agences vous disent vraiment."
     stays on one line (wraps only on small phones) */
  #rdv h2 { max-width: none; }
  .bookdemo__hint {
    text-align: center;
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: 12px;
  }
  .bookdemo__calendar {
    margin-top: 20px;
  }
  .bookdemo__calendar-box {
    display: grid;
    place-items: center;
    min-height: 220px;
    padding: 24px;
    text-align: center;
    border: 1px dashed var(--faint);
    border-radius: 12px;
    background: var(--surface2);
    color: var(--muted);
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById("bookdemo-form");
    var calendar = document.getElementById("bookdemo-calendar");
    if (!form || !calendar) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      // Front-only: no submission yet. Reveal the calendar embed placeholder.
      form.setAttribute("hidden", "");
      calendar.removeAttribute("hidden");
      calendar.scrollIntoView({ behavior: "smooth", block: "nearest" });

      try {
        var tracker = window.reedlyTrackEvent;
        if (typeof tracker === "function") {
          tracker("landing_bookdemo_qualified", {
            role: form.querySelector("#bd-role") ? form.querySelector("#bd-role").value : "",
            team_size: form.querySelector("#bd-team") ? form.querySelector("#bd-team").value : "",
          });
        }
      } catch (err) {}
    });
  })();
</script>
