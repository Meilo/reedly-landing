---
// Footer
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
---

<footer class="footer z1">
  <div class="footer__inner">
    <div class="footer__brand">
      <a class="footer__logo" href={`/${lang}`} data-link-fr="/fr" data-link-en="/en">
        <img src="/favicon.png" alt="Reedly" width="24" height="24" style="border-radius: 6px;" />
        <span>REEDLY</span>
      </a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.product">Produit</div>
      <a href={`/${lang}#rdv`} data-i18n="footer.book_demo" data-link-fr="/fr#rdv" data-link-en="/en#rdv">Réserver une démo</a>
      <a href={lang === 'fr' ? '/fr/tarifs' : '/en/pricing'} data-i18n="footer.pricing" data-link-fr="/fr/tarifs" data-link-en="/en/pricing">Tarifs</a>
      <a href={`/${lang}/blog`} data-i18n="footer.blog" data-link-fr="/fr/blog" data-link-en="/en/blog">Blog</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title">{lang === 'fr' ? 'Fonctionnalités' : 'Features'}</div>
      <a href={lang === 'fr' ? '/fr/features/enregistrement-vocal-rdv' : '/en/features/meeting-voice-recording'}>{lang === 'fr' ? 'Enregistrement vocal' : 'Voice Recording'}</a>
      <a href={lang === 'fr' ? '/fr/features/rapport-ia' : '/en/features/ai-report'}>{lang === 'fr' ? 'Rapport structuré IA' : 'AI Report'}</a>
      <a href={lang === 'fr' ? '/fr/features/hub-manager' : '/en/features/manager-hub'}>{lang === 'fr' ? 'Hub Manager' : 'Manager Hub'}</a>
      <a href={lang === 'fr' ? '/fr/features/integrations-crm' : '/en/features/crm-integrations'}>{lang === 'fr' ? 'Intégrations CRM' : 'CRM Integrations'}</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title">{lang === 'fr' ? 'Comparatif' : 'Compare'}</div>
      <a
        href={lang === 'fr' ? '/fr/alternatives/noota' : '/en/alternatives/noota'}
        data-link-fr="/fr/alternatives/noota"
        data-link-en="/en/alternatives/noota"
      >{lang === 'fr' ? 'Alternative à Noota' : 'Noota alternative'}</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.legal">Legal</div>
      <a href={lang === 'fr' ? '/fr/confidentialite' : '/en/privacy-policy'} data-i18n="footer.privacy" data-link-fr="/fr/confidentialite" data-link-en="/en/privacy-policy">Confidentialite</a>
      <a href={lang === 'fr' ? '/fr/cgu' : '/en/terms-of-service'} data-i18n="footer.terms" data-link-fr="/fr/cgu" data-link-en="/en/terms-of-service">CGU</a>
      <a href={`/${lang}#rdv`} data-i18n="footer.contact" data-link-fr="/fr#rdv" data-link-en="/en#rdv">Contact</a>
    </div>

  </div>

  <!-- Bottom bar: identity + socials on the left, the reps' app (demoted) on the right -->
  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <div class="footer__bottom-left">
        <div class="footer__copy" data-i18n="footer.copy">© 2026 Reedly. Tous droits reserves</div>

        <!-- Social links -->
        <div class="footer__social">
          <a
            class="footer__social-link"
            href="https://www.linkedin.com/company/reedly/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            data-track-id="footer_social_linkedin"
            data-track-type="social"
            data-track-section="footer"
          >
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              />
            </svg>
          </a>
          <a
            class="footer__social-link"
            href="https://www.instagram.com/reedly.ai/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            data-track-id="footer_social_instagram"
            data-track-type="social"
            data-track-section="footer"
          >
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              />
            </svg>
          </a>
        </div>
      </div>

      <!-- App stores, the reps' tool (demoted from any primary position) -->
      <div class="footer__bottom-right">
        <span class="footer__stores-label" data-i18n="footer.stores.label">Pour vos commerciaux</span>
        <div class="footer__stores-row">
          <a
            class="store-badge store-badge--sm"
            href="https://apps.apple.com/fr/app/reedly-rapport-g%C3%A9n%C3%A9r%C3%A9-par-ia/id6760261826"
            data-link-fr="https://apps.apple.com/fr/app/reedly-rapport-g%C3%A9n%C3%A9r%C3%A9-par-ia/id6760261826"
            data-link-en="https://apps.apple.com/app/reedly-rapport-g%C3%A9n%C3%A9r%C3%A9-par-ia/id6760261826"
            target="_blank"
            rel="noopener noreferrer"
            data-store="ios"
            data-track-id="footer_store_ios"
            data-track-type="download"
            data-track-section="footer"
          >
            <svg viewBox="0 0 814 1000" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76 0-103.7 40.8-165.9 40.8s-105-57.8-155.5-127.4C46 790.7 0 663 0 541.8c0-207.3 133.4-316.9 264.6-316.9 70.1 0 128.4 46.4 172.1 46.4 41.8 0 107.2-49.1 183.2-49.1 29.2 0 130.4 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"
              />
            </svg>
            <div class="store-badge__text">
              <span class="store-badge__sub" data-i18n="cta.store_sub">Disponible sur</span>
              <span class="store-badge__name">App Store</span>
            </div>
          </a>
          <a
            class="store-badge store-badge--sm"
            href="https://play.google.com/store/apps/details?id=com.reedly.app"
            target="_blank"
            rel="noopener noreferrer"
            data-track-id="footer_store_android"
            data-track-type="download"
            data-track-section="footer"
          >
            <svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M48 59.49v393a4.33 4.33 0 007.37 3.07l232-233.5a4.33 4.33 0 000-6.14L55.37 56.42A4.33 4.33 0 0048 59.49zM400.35 256.28l-75.5 76.07-30.85-30.85c-1.57-1.57-4.12-1.57-5.69 0-1.57 1.57-1.57 4.12 0 5.69l33.7 33.7a4.02 4.02 0 005.69 0l78.35-78.93V256c0-1.96-1.57-4.12-3.53-5.69z"
              />
              <path
                d="M400.35 256.28l-12.23 12.23c-1.57 1.57-4.12 1.57-5.69 0l-26.84-26.84c-1.57-1.57-1.57-4.12 0-5.69l44.76-45.13V256c0 .1 0 .19-.01.28zM260.61 285.14L55.37 452.56A4.29 4.29 0 0148 449.49V62.57z"
              />
            </svg>
            <div class="store-badge__text">
              <span class="store-badge__sub" data-i18n="cta.store_sub">Disponible sur</span>
              <span class="store-badge__name">Google Play</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .footer__stores-label {
      display: block;
      font-family: var(--mono);
      font-size: 0.66rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--faint);
      margin-bottom: 10px;
    }
    .footer__stores-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .footer__signin {
      color: var(--muted);
    }
  </style>
</footer>

<!-- ── Notify modal (dormant unless a store link is set to "#") ── -->
<div class="notify-modal" id="notify-modal" aria-hidden="true">
  <div class="notify-modal__backdrop" id="notify-modal-backdrop"></div>
  <div class="notify-modal__dialog">
    <button class="notify-modal__close" id="notify-modal-close" type="button" aria-label="Fermer">&times;</button>
    <h3 class="notify-modal__title" data-i18n="notify.title">Bientôt disponible</h3>
    <p class="notify-modal__text" data-i18n="notify.text">
      L'application n'est pas encore sur les stores. Laissez votre email pour être prévenu(e) dès sa sortie.
    </p>
    <form class="notify-modal__form" id="notify-form">
      <input
        class="notify-modal__input"
        type="email"
        id="notify-email"
        required
        data-i18n-placeholder="notify.placeholder"
        placeholder="votre@email.com"
      />
      <button class="btn btn--primary btn--md notify-modal__submit" type="submit">
        <span data-i18n="notify.cta">Me prévenir</span>
      </button>
    </form>
    <div class="notify-modal__feedback" id="notify-feedback"></div>
  </div>
</div>
