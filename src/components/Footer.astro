---
// Footer
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const lang = path.startsWith('/en') ? 'en' : 'fr';
---

<footer class="footer z1">
  <div class="footer__inner">
    <div class="footer__brand">
      <a class="footer__logo" href={`/${lang}`} data-link-fr="/fr" data-link-en="/en">
        <img src="/favicon.png" alt="Reedly" width="24" height="24" style="border-radius: 6px;" />
        <span>REEDLY</span>
      </a>
      <div class="footer__copy" data-i18n="footer.copy">© 2026 Reedly — Tous droits reserves</div>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.product">Produit</div>
      <a href={lang === 'fr' ? '/fr/tarifs' : '/en/pricing'} data-i18n="footer.pricing" data-link-fr="/fr/tarifs" data-link-en="/en/pricing">Tarifs</a>
      <a href={lang === 'fr' ? '/fr/comparatif' : '/en/comparison'} data-i18n="footer.comparatif" data-link-fr="/fr/comparatif" data-link-en="/en/comparison">Comparatif</a>
      <a href={`/${lang}/blog`} data-i18n="footer.blog" data-link-fr="/fr/blog" data-link-en="/en/blog">Blog</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title">{lang === 'fr' ? 'Fonctionnalités' : 'Features'}</div>
      <a href={lang === 'fr' ? '/fr/features/enregistrement-vocal-rdv' : '/en/features/meeting-voice-recording'}>{lang === 'fr' ? 'Enregistrement vocal' : 'Voice Recording'}</a>
      <a href={lang === 'fr' ? '/fr/features/rapport-ia' : '/en/features/ai-report'}>{lang === 'fr' ? 'Rapport structuré IA' : 'AI Report'}</a>
      <a href={lang === 'fr' ? '/fr/features/hub-manager' : '/en/features/manager-hub'}>{lang === 'fr' ? 'Hub Manager' : 'Manager Hub'}</a>
      <a href={lang === 'fr' ? '/fr/features/integrations-crm' : '/en/features/crm-integrations'}>{lang === 'fr' ? 'Intégrations CRM' : 'CRM Integrations'}</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.legal">Legal</div>
      <a href={lang === 'fr' ? '/fr/confidentialite' : '/en/privacy-policy'} data-i18n="footer.privacy" data-link-fr="/fr/confidentialite" data-link-en="/en/privacy-policy">Confidentialite</a>
      <a href={lang === 'fr' ? '/fr/cgu' : '/en/terms-of-service'} data-i18n="footer.terms" data-link-fr="/fr/cgu" data-link-en="/en/terms-of-service">CGU</a>
      <a href={`/${lang}#contact`} data-i18n="footer.contact">Contact</a>
    </div>

    <div class="footer__col footer__col--ph">
      <a
        href="https://www.producthunt.com/products/reedly?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-reedly"
        target="_blank"
        rel="noopener noreferrer"
        class="footer__ph-badge"
      >
        <img
          src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1111378&theme=neutral&t=1774876402712"
          alt="Reedly - Turn field meetings into structured AI reports — in seconds. | Product Hunt"
          width="250"
          height="54"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>
