---
// Footer
---

<footer class="footer z1">
  <div class="footer__inner">
    <div class="footer__brand">
      <a class="footer__logo" href="/">
        <img src="/favicon.png" alt="Reedly" width="24" height="24" style="border-radius: 6px;" />
        <span>REEDLY</span>
      </a>
      <div class="footer__copy" data-i18n="footer.copy">© 2026 Reedly — Tous droits reserves</div>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.product">Produit</div>
      <a href="/solution" data-i18n="footer.solution" data-link-fr="/solution" data-link-en="/solution">Solution</a>
      <a href="/tarifs" data-i18n="footer.pricing" data-link-fr="/tarifs" data-link-en="/pricing">Tarifs</a>
      <a href="/comparatif" data-i18n="footer.comparatif" data-link-fr="/comparatif" data-link-en="/comparison">Comparatif</a>
      <a href="/blog" data-i18n="footer.blog" data-link-fr="/blog" data-link-en="/blog">Blog</a>
    </div>

    <div class="footer__col">
      <div class="footer__col-title" data-i18n="footer.col.legal">Legal</div>
      <a href="/confidentialite" data-i18n="footer.privacy" data-link-fr="/confidentialite" data-link-en="/privacy-policy">Confidentialite</a>
      <a href="/cgu" data-i18n="footer.terms" data-link-fr="/cgu" data-link-en="/terms-of-service">CGU</a>
      <a href="/#contact" data-i18n="footer.contact">Contact</a>
    </div>
  </div>
</footer>
