{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "lang": {
      "type": "string",
      "enum": [
        "fr",
        "en"
      ]
    },
    "mirror": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "readingTime": {
      "type": "number"
    },
    "author": {
      "type": "string",
      "enum": [
        "laura",
        "ludovic"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "date",
    "lang",
    "mirror",
    "keywords",
    "readingTime",
    "author"
  ]
}