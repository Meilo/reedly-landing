# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address that receives contact form submissions
CONTACT_TO_EMAIL=contact@reedly.ai

# Sender email (must be a verified domain in Resend)
CONTACT_FROM_EMAIL=noreply@reedly.ai

# PostHog web analytics
PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
PUBLIC_POSTHOG_DEFAULTS=2026-01-30

# Booking calendar (Google) — host Workspace account
# Generate the refresh token once with: node scripts/google-oauth.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
# The internal booking notification reuses RESEND_API_KEY / CONTACT_TO_EMAIL / CONTACT_FROM_EMAIL above.
